<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LlamaChat.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="LlamaChat.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="LlamaChat — LlamaCpp.Bindings sample"
        Width="900" Height="650" MinWidth="560" MinHeight="400">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="12">

        <!-- Model picker row -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,12" ColumnSpacing="6">
            <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox  Grid.Column="1"
                      Text="{Binding ModelPath, Mode=TwoWay}"
                      IsEnabled="{Binding !IsModelLoaded}"
                      PlaceholderText="/path/to/model.gguf"/>
            <Button   Grid.Column="2"
                      Content="Load"
                      Command="{Binding LoadCommand}"
                      IsVisible="{Binding !IsModelLoaded}"
                      IsEnabled="{Binding !IsBusy}"
                      MinWidth="90"/>
            <Button   Grid.Column="2"
                      Content="Unload"
                      Command="{Binding LoadCommand}"
                      IsVisible="{Binding IsModelLoaded}"
                      IsEnabled="{Binding !IsBusy}"
                      MinWidth="90"/>
            <Button   Grid.Column="3"
                      Content="Clear"
                      Command="{Binding ClearConversationCommand}"
                      IsEnabled="{Binding IsModelLoaded}"
                      MinWidth="70"/>
        </Grid>

        <!-- Chat history -->
        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                CornerRadius="4"
                Padding="8">
            <ScrollViewer Name="ChatScroll" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ChatMessageViewModel">
                            <Border Margin="0,4"
                                    Padding="10,6"
                                    CornerRadius="6"
                                    Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Role}"
                                               FontWeight="SemiBold"
                                               Opacity="0.65"
                                               FontSize="12"/>
                                    <SelectableTextBlock Text="{Binding Content}"
                                                         TextWrapping="Wrap"
                                                         Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Sampling settings -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,150,Auto,150,Auto,150"
              Margin="0,12,0,6"
              ColumnSpacing="8"
              IsEnabled="{Binding !IsGenerating}">
            <TextBlock Grid.Column="0"
                       Text="Temp:"
                       VerticalAlignment="Center"
                       ToolTip.Tip="Sampling temperature. 0 = greedy (most likely token). 0.7 is a good default for chat. Higher values flatten the probability distribution and make output more varied."/>
            <NumericUpDown Grid.Column="1"
                           Value="{Binding Temperature}"
                           Minimum="0" Maximum="2" Increment="0.1"
                           FormatString="0.0"
                           ToolTip.Tip="Sampling temperature. 0 = greedy (most likely token). 0.7 is a good default for chat. Higher values flatten the probability distribution and make output more varied."/>
            <TextBlock Grid.Column="2"
                       Text="Seed:"
                       VerticalAlignment="Center"
                       ToolTip.Tip="RNG seed for stochastic sampling. Same seed + same prompt + same sampler = reproducible output (on CUDA with MoE models, only seeded sampling is truly reproducible; greedy can drift)."/>
            <NumericUpDown Grid.Column="3"
                           Value="{Binding Seed}"
                           Minimum="0" Maximum="999999" Increment="1"
                           FormatString="0"
                           ToolTip.Tip="RNG seed for stochastic sampling. Same seed + same prompt + same sampler = reproducible output."/>
            <TextBlock Grid.Column="4"
                       Text="Max tokens:"
                       VerticalAlignment="Center"
                       ToolTip.Tip="Maximum tokens generated per turn. A safety cap, not a target — generation stops earlier when the model emits an end-of-turn token. Increase if the model is getting cut off mid-sentence."/>
            <NumericUpDown Grid.Column="5"
                           Value="{Binding MaxTokens}"
                           Minimum="16" Maximum="8192" Increment="64"
                           FormatString="0"
                           ToolTip.Tip="Maximum tokens generated per turn. A safety cap, not a target — generation stops earlier when the model emits an end-of-turn token."/>
        </Grid>

        <!-- Input row + status -->
        <Grid Grid.Row="3" RowDefinitions="Auto,Auto" RowSpacing="6">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                <TextBox Grid.Column="0"
                         Text="{Binding UserInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="48"
                         MaxHeight="150"
                         PlaceholderText="Type a message and press Send..."
                         IsEnabled="{Binding IsModelLoaded}"/>
                <Button Grid.Column="1"
                        Content="Send"
                        Command="{Binding SendCommand}"
                        IsDefault="True"
                        MinWidth="80"/>
                <Button Grid.Column="2"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        MinWidth="80"/>
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="{Binding StatusText}"
                       FontSize="11"
                       Opacity="0.7"
                       TextWrapping="Wrap"/>
        </Grid>
    </Grid>

</Window>
