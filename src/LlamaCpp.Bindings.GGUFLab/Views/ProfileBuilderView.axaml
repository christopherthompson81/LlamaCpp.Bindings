<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             xmlns:v="using:LlamaCpp.Bindings.GGUFLab.Views"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.ProfileBuilderView"
             x:DataType="vm:ProfileBuilderViewModel">

    <DockPanel Margin="24,18">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Footer: progress + status + log -->
        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto,Auto,Auto,160" Margin="0,12,0,0">
            <Grid Grid.Row="0" ColumnDefinitions="120,*" ColumnSpacing="10" Margin="0,0,0,4"
                  IsVisible="{Binding IsRunning}">
                <TextBlock Grid.Column="0" Text="Stage" Opacity="0.6" FontSize="11" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding StageText}"
                           FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                           FontSize="11" />
            </Grid>
            <ProgressBar Grid.Row="1"
                         Minimum="0" Maximum="1"
                         Value="{Binding ProgressFraction}"
                         IsVisible="{Binding IsRunning}"
                         Height="4"
                         Margin="0,0,0,6" />
            <TextBlock Grid.Row="2"
                       Text="{Binding ProgressLabel}"
                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                       FontSize="11"
                       Opacity="0.65"
                       Margin="0,0,0,4"
                       TextTrimming="CharacterEllipsis"
                       IsVisible="{Binding IsRunning}" />
            <TextBlock Grid.Row="3"
                       Text="{Binding StatusLine}"
                       Margin="0,0,0,6"
                       Opacity="0.85"
                       TextWrapping="Wrap" />
            <Border Grid.Row="4"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="{DynamicResource SystemAltLowColor}">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogText}"
                                         FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                         FontSize="12"
                                         Padding="10,8"
                                         TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Form -->
        <ScrollViewer>
            <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">

                <!-- File pickers -->
                <Grid ColumnDefinitions="140,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Source GGUF" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="0">
                        <TextBox Text="{Binding SourceModelPath}"
                                 PlaceholderText="F16 .gguf — the campaign quantizes to it as the baseline" />
                        <v:RemedyCard />
                    </StackPanel>
                    <Button   Grid.Row="0" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseSource" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Corpus" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding CorpusPath}"
                              PlaceholderText="Calibration text (e.g. wiki.test.raw)" />
                    <Button   Grid.Row="1" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseCorpus" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Imatrix" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="0">
                        <TextBox Text="{Binding ImatrixPath}"
                                 PlaceholderText="(optional) imatrix .gguf — recommended for production-realistic profiles" />
                        <v:BuildImatrixRemedyCard />
                    </StackPanel>
                    <Button   Grid.Row="2" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseImatrix" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Working dir" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding WorkingDirectory}"
                              PlaceholderText="(optional) fast disk for temp quants — defaults to a fresh tempdir" />
                    <Button   Grid.Row="3" Grid.Column="2" Content="Browse…"
                              Click="OnBrowseWorkingDir" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Output profile" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="4" Grid.Column="1" Text="{Binding OutputProfilePath}"
                              PlaceholderText="Leave blank to derive from source — &lt;name&gt;.profile.json" />
                    <Button   Grid.Row="4" Grid.Column="2" Content="Browse…"
                              Click="OnBrowseOutput" />
                </Grid>

                <!-- Mode toggle -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Campaign mode" FontWeight="SemiBold" FontSize="11" Opacity="0.7" />
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <RadioButton GroupName="Mode" Content="Per-category (cheap)"
                                         IsChecked="{Binding IsPerCategory}"
                                         Click="OnModePerCategory" />
                            <RadioButton GroupName="Mode" Content="Per-layer (expensive — days for big models)"
                                         IsChecked="{Binding IsPerLayer}"
                                         Click="OnModePerLayer" />
                        </StackPanel>
                        <TextBlock FontSize="11" Opacity="0.6" TextWrapping="Wrap">
                            Per-category ablates a whole tensor pattern at once (~22 PPL for the default ladder).
                            Per-layer ablates each tensor individually — strictly more data, lets the recipe demote
                            tensors that are below their category average. Both modes accumulate into the global
                            investigation DB; mixing modes for the same model is encouraged.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Detected architecture (read-only) -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Detected architecture" FontWeight="SemiBold" FontSize="11" Opacity="0.7" />
                        <Grid ColumnDefinitions="120,*" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="arch" Opacity="0.6" />
                            <TextBlock Grid.Column="1" Text="{Binding DetectedArchitecture}"
                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="layers" Opacity="0.6" />
                            <TextBlock Grid.Column="1" Text="{Binding DetectedLayerCount}"
                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*" ColumnSpacing="10"
                              IsVisible="{Binding IsPerLayer}">
                            <TextBlock Grid.Column="0" Text="per-layer tensors" Opacity="0.6" />
                            <TextBlock Grid.Column="1" Text="{Binding PerLayerTensorCount}"
                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Categories (per-category mode only) -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding IsPerCategory}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Categories (auto-detected from architecture)"
                                   FontWeight="SemiBold" FontSize="11" Opacity="0.7" />
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ProfileBuilderViewModel+CategoryItem">
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              MinWidth="180"
                                              Margin="0,2,12,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Categories come from src/LlamaCpp.Bindings/HfConvert/architectures/. Tensors not present in this specific model are auto-filtered (e.g. tied-embedding models drop output.weight)."
                                   FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Candidate types -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Candidate types (one PPL run per target × type)"
                                   FontWeight="SemiBold" FontSize="11" Opacity="0.7" />
                        <WrapPanel Orientation="Horizontal" ItemWidth="120">
                            <CheckBox Content="IQ2_S"  IsChecked="{Binding UseIQ2S, Mode=TwoWay}"
                                      ToolTip.Tip="2.5 bpw — codebook + importance, often beats Q2_K on per-tensor profile" />
                            <CheckBox Content="Q2_K"   IsChecked="{Binding UseQ2K, Mode=TwoWay}"
                                      ToolTip.Tip="2.625 bpw — block-256 super-block scaling" />
                            <CheckBox Content="IQ3_S"  IsChecked="{Binding UseIQ3S, Mode=TwoWay}"
                                      ToolTip.Tip="3.44 bpw — IQ-family, often beats Q3_K" />
                            <CheckBox Content="Q3_K"   IsChecked="{Binding UseQ3K, Mode=TwoWay}"
                                      ToolTip.Tip="3.4375 bpw" />
                            <CheckBox Content="IQ4_XS" IsChecked="{Binding UseIQ4XS, Mode=TwoWay}"
                                      ToolTip.Tip="4.25 bpw — non-linear Q4 variant" />
                            <CheckBox Content="Q4_K"   IsChecked="{Binding UseQ4K, Mode=TwoWay}"
                                      ToolTip.Tip="4.5 bpw" />
                            <CheckBox Content="Q5_K"   IsChecked="{Binding UseQ5K, Mode=TwoWay}"
                                      ToolTip.Tip="5.5 bpw" />
                            <CheckBox Content="Q6_K"   IsChecked="{Binding UseQ6K, Mode=TwoWay}"
                                      ToolTip.Tip="6.5625 bpw" />
                            <CheckBox Content="Q8_0"   IsChecked="{Binding UseQ8_0, Mode=TwoWay}"
                                      ToolTip.Tip="8.5 bpw — usually within noise of F16" />
                        </WrapPanel>
                        <TextBlock Text="{Binding CostEstimateText}"
                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                   FontSize="11" Opacity="0.75" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Tuning -->
                <Expander Header="Tuning" IsExpanded="False">
                    <StackPanel Spacing="10" Margin="0,8,0,0">
                        <Grid ColumnDefinitions="200,*,90" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="PPL context size" VerticalAlignment="Center"
                                       ToolTip.Tip="Token window per PPL chunk. 512 matches published wiki.test numbers; longer ctx tightens variance at proportional compute cost." />
                            <Slider Grid.Column="1" Minimum="128" Maximum="2048" SmallChange="64" LargeChange="256"
                                    Value="{Binding ContextSize, Mode=TwoWay}" />
                            <TextBox Grid.Column="2" Text="{Binding ContextSize, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="200,*,90" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Knee ΔPPL threshold" VerticalAlignment="Center"
                                       ToolTip.Tip="A category's recommendedFloor is the smallest type whose ΔPPL stays below this threshold. 5.0 = generous (catches genuine knees, ignores mild degradation)." />
                            <Slider Grid.Column="1" Minimum="0.5" Maximum="20.0" SmallChange="0.5" LargeChange="2.0"
                                    Value="{Binding KneeDeltaPplThreshold, Mode=TwoWay}" />
                            <TextBox Grid.Column="2" Text="{Binding KneeDeltaPplThreshold, Mode=TwoWay, StringFormat=F1}"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="200,*,90" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Max concurrent (0=auto)" VerticalAlignment="Center"
                                       ToolTip.Tip="Concurrency cap for the inner PPL runner. 0 = auto-detect from per-batch file sizes vs available VRAM." />
                            <Slider Grid.Column="1" Minimum="0" Maximum="16" SmallChange="1" LargeChange="2"
                                    Value="{Binding MaxConcurrent, Mode=TwoWay}" />
                            <TextBox Grid.Column="2" Text="{Binding MaxConcurrent, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="200,*,90" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Available VRAM (GB)" VerticalAlignment="Center"
                                       ToolTip.Tip="Used by the auto-concurrency heuristic. Default 24 = RTX 3090 class. Drop lower for tighter hardware." />
                            <Slider Grid.Column="1" Minimum="4" Maximum="80" SmallChange="1" LargeChange="4"
                                    Value="{Binding AvailableVramGb, Mode=TwoWay}" />
                            <TextBox Grid.Column="2" Text="{Binding AvailableVramGb, Mode=TwoWay, StringFormat=F0}"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <CheckBox Content="Cleanup working directory when finished"
                                  IsChecked="{Binding CleanupWorkingDirectory, Mode=TwoWay}" />
                    </StackPanel>
                </Expander>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Content="Build profile"
                            Command="{Binding BuildCommand}"
                            IsEnabled="{Binding IsIdle}"
                            Classes="accent" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}" />
                </StackPanel>

                <!-- Progress grid: rows = ablation targets, cols = candidate types.
                     Shape is allocated once per campaign (Plan event); per-cell
                     state updates flow through observable cell properties so the
                     layout doesn't reshape on each tick. Each cell is fixed-width
                     (60 px) so resize is window-driven, not data-driven. -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        IsVisible="{Binding ProgressRows.Count}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Progress grid"
                                   FontWeight="SemiBold" FontSize="11" Opacity="0.7"
                                   Margin="0,0,0,6" />
                        <!-- Column header row -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="" Width="240" />
                            <ItemsControl ItemsSource="{Binding ProgressColumnHeaders}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="x:String">
                                        <TextBlock Text="{Binding}"
                                                   Width="60"
                                                   TextAlignment="Center"
                                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.7" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <!-- Body: scrollable rows -->
                        <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ProgressRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ProfileBuilderViewModel+ProgressRow">
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <TextBlock Text="{Binding Label}"
                                                       Width="240"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:ProfileBuilderViewModel+ProgressCell">
                                                        <Border Width="58" Height="22" Margin="1,0"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource SystemBaseLowColor}"
                                                                CornerRadius="2"
                                                                Background="{DynamicResource SystemAltLowColor}">
                                                            <StackPanel Orientation="Horizontal" Spacing="3"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Glyph}"
                                                                           FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding DeltaText}"
                                                                           FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                                           FontSize="10"
                                                                           Opacity="0.7"
                                                                           VerticalAlignment="Center"
                                                                           IsVisible="{Binding IsDone}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
