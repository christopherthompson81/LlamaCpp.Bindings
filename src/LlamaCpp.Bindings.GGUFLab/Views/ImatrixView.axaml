<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             xmlns:v="using:LlamaCpp.Bindings.GGUFLab.Views"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.ImatrixView"
             x:DataType="vm:ImatrixViewModel">

    <DockPanel Margin="24,18">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Footer: action buttons (sticky), status + timing, progress,
             params snapshot, result, log. All rows are Auto-sized and the
             log Border has an explicit height so the form ScrollViewer
             above gets the rest of the window. Without this, the * row
             ate all available space and the buttons disappeared. -->
        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,12,0,0">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <Button Content="Run"
                        Command="{Binding RunCommand}"
                        IsEnabled="{Binding IsIdle}"
                        Classes="accent" />
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsRunning}" />
                <Button Content="Save log…"
                        Click="OnSaveLog"
                        IsEnabled="{Binding HasFullLog}"
                        ToolTip.Tip="Save the un-deduped, un-truncated log of the last run." />
            </StackPanel>
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="14" Margin="0,0,0,4">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusLine}"
                           Opacity="0.85"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14"
                            IsVisible="{Binding ElapsedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Opacity="0.75" FontFamily="Cascadia Mono, Menlo, Consolas, monospace" FontSize="12">
                        <Run Text="elapsed " /><Run Text="{Binding ElapsedText}" />
                    </TextBlock>
                    <TextBlock Opacity="0.55" FontFamily="Cascadia Mono, Menlo, Consolas, monospace" FontSize="12">
                        <Run Text="ETA " /><Run Text="{Binding EtaText}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
            <ProgressBar Grid.Row="2"
                         Value="{Binding ProgressFraction}"
                         Minimum="0" Maximum="1"
                         Height="4"
                         Margin="0,0,0,8" />
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14,10"
                    Margin="0,0,0,8"
                    IsVisible="{Binding RunParametersText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <SelectableTextBlock Text="{Binding RunParametersText}"
                                     FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                     FontSize="12"
                                     Opacity="0.85" />
            </Border>
            <Border Grid.Row="4"
                    BorderBrush="{DynamicResource SystemAccentColorLight2}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14,10"
                    Margin="0,0,0,8"
                    IsVisible="{Binding ResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <SelectableTextBlock Text="{Binding ResultText}"
                                     FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                     FontSize="13" />
            </Border>
            <Border Grid.Row="5"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Height="220"
                    Background="{DynamicResource SystemAltLowColor}">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogText}"
                                         FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                         FontSize="12"
                                         Padding="10,8"
                                         TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Form -->
        <ScrollViewer>
            <StackPanel Spacing="14" MaxWidth="780" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Model GGUF" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="0">
                        <TextBox Text="{Binding ModelPath}"
                                 PlaceholderText="Path to a .gguf model" />
                        <v:RemedyCard />
                    </StackPanel>
                    <Button   Grid.Row="0" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseModel" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Corpus file" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding CorpusPath}"
                              PlaceholderText="Optional — paste below to skip the file" />
                    <Button   Grid.Row="1" Grid.Column="2" Content="Browse…"
                              Click="OnBrowseCorpus" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Output GGUF" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding OutputPath}"
                              PlaceholderText="Leave blank to derive from model name" />
                    <Button   Grid.Row="2" Grid.Column="2" Content="Browse…"
                              Click="OnBrowseOutput" />
                </Grid>

                <!-- Corpus remedy card. Shape matches the convert / build-
                     imatrix remedies so the user reads "card means there's
                     a one-click fix for what's missing" the same way each
                     time. Info-blue (not warn-amber) since loading the
                     standard corpus is optional — pasting your own works
                     just as well. -->
                <Border Background="#332563EB"
                        BorderBrush="#2563EB"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        IsVisible="{Binding ShowLoadWikitextRemedy}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Viewbox Grid.Column="0"
                                 Width="20" Height="20"
                                 VerticalAlignment="Center">
                            <Path Data="{StaticResource BriefcaseMedicalIcon}"
                                  Stroke="#2563EB"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round" />
                        </Viewbox>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="No calibration corpus yet."
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="An imatrix needs text to score column importance. wikitext-2 (~1.18 MB) is the standard fast-start corpus; cached after first fetch."
                                       FontSize="11"
                                       Opacity="0.8"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Load wikitext-2"
                                Command="{Binding LoadWikitextCommand}"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Fetch (or read from cache) the standard calibration corpus from HuggingFace." />
                    </Grid>
                </Border>

                <StackPanel Spacing="4">
                    <TextBlock Text="Corpus text" Opacity="0.85" />
                    <TextBox Text="{Binding CorpusText, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="100"
                             MaxHeight="200"
                             FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                             FontSize="12"
                             PlaceholderText="Paste a calibration passage or load wikitext-2 above. Larger = better imatrix." />
                </StackPanel>

                <Expander Header="Advanced options">
                    <StackPanel Spacing="10" Margin="0,8,0,0">
                        <Grid ColumnDefinitions="160,Auto" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Context size (tokens)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="0" Grid.Column="1"
                                           Value="{Binding ContextSize, Mode=TwoWay}"
                                           Minimum="8" Maximum="32768" Increment="128"
                                           FormatString="0" Width="140" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="GPU layers (-1 = all)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                           Value="{Binding GpuLayerCount, Mode=TwoWay}"
                                           Minimum="-1" Maximum="999" Increment="1"
                                           FormatString="0" Width="140" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Threads" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                           Value="{Binding ThreadCount, Mode=TwoWay}"
                                           Minimum="-1" Maximum="256" Increment="1"
                                           FormatString="0" Width="140"
                                           ToolTip.Tip="Defaults to physical-core count (logical/2) — full SMT typically contends on SIMD units. Bump up on non-SMT chips, dial down on contended boxes. -1 falls back to llama.cpp's hard-coded 4-thread default." />
                        </Grid>
                        <CheckBox IsChecked="{Binding ProcessOutput, Mode=TwoWay}"
                                  Content="Include output.weight in the imatrix (most quants don't need this)" />
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
