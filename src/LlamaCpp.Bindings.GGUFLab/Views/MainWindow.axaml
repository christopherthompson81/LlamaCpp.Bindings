<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
        xmlns:v="using:LlamaCpp.Bindings.GGUFLab.Views"
        x:Class="LlamaCpp.Bindings.GGUFLab.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="GGUF Lab"
        Icon="/Assets/icon-256.png"
        Width="1100" Height="720"
        MinWidth="780" MinHeight="520">

    <Window.Resources>
        <DataTemplate x:Key="HfBrowserTemplate" DataType="vm:HfBrowserViewModel">
            <v:HfBrowserView />
        </DataTemplate>
        <DataTemplate x:Key="LocalModelsTemplate" DataType="vm:LocalModelsViewModel">
            <v:LocalModelsView />
        </DataTemplate>
        <DataTemplate x:Key="QuantizeTemplate" DataType="vm:QuantizeViewModel">
            <v:QuantizeView />
        </DataTemplate>
        <DataTemplate x:Key="AdaptiveQuantizeTemplate" DataType="vm:AdaptiveQuantizeViewModel">
            <v:AdaptiveQuantizeView />
        </DataTemplate>
        <DataTemplate x:Key="PerplexityTemplate" DataType="vm:PerplexityViewModel">
            <v:PerplexityView />
        </DataTemplate>
        <DataTemplate x:Key="KlDivergenceTemplate" DataType="vm:KlDivergenceViewModel">
            <v:KlDivergenceView />
        </DataTemplate>
        <DataTemplate x:Key="HellaswagTemplate" DataType="vm:HellaswagViewModel">
            <v:HellaswagView />
        </DataTemplate>
        <DataTemplate x:Key="ImatrixTemplate" DataType="vm:ImatrixViewModel">
            <v:ImatrixView />
        </DataTemplate>
        <DataTemplate x:Key="ControlVectorTemplate" DataType="vm:ControlVectorViewModel">
            <v:ControlVectorView />
        </DataTemplate>
        <DataTemplate x:Key="GgufEditorTemplate" DataType="vm:GgufEditorViewModel">
            <v:GgufEditorView />
        </DataTemplate>
        <DataTemplate x:Key="ShardingTemplate" DataType="vm:ShardingViewModel">
            <v:ShardingView />
        </DataTemplate>
        <DataTemplate x:Key="HfConvertTemplate" DataType="vm:HfConvertViewModel">
            <v:HfConvertView />
        </DataTemplate>
        <DataTemplate x:Key="LoraMergeTemplate" DataType="vm:LoraMergeViewModel">
            <v:LoraMergeView />
        </DataTemplate>
        <DataTemplate x:Key="RoadmapTemplate" DataType="vm:RoadmapViewModel">
            <v:RoadmapView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="OnExitClicked" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Preferences..." Click="OnPreferencesClicked" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Click="OnAboutClicked" />
            </MenuItem>
        </Menu>

    <Grid ColumnDefinitions="220,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SystemListLowColor}" Padding="0,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="GGUF Lab"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="16,4,16,12" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Model preparation"
                           FontSize="11"
                           Opacity="0.6"
                           Margin="16,0,16,8" />
                <ListBox ItemsSource="{Binding Tools}"
                         SelectedItem="{Binding SelectedTool, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:ToolPageViewModel">
                            <StackPanel Margin="4,2">
                                <TextBlock Text="{Binding Title}" FontWeight="Medium" />
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Opacity="0.6"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content host with active-model strip on top. The strip is
             always visible so the HF Browser / Local Models picks
             follow the user across tools. -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource SystemListLowColor}"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="0,0,0,1"
                    Padding="14,6"
                    IsVisible="{Binding ActiveModel.HasModel}">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0"
                               Text="Active model:"
                               Opacity="0.65"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ActiveModel.DisplayName}"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding ActiveModel.Path}" />
                    <Button   Grid.Column="3"
                              Content="Clear"
                              Padding="8,2"
                              Click="OnClearActiveModelClicked" />
                </Grid>
            </Border>
        <ContentControl Content="{Binding SelectedTool}"
                        Margin="0">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:HfBrowserViewModel">
                    <v:HfBrowserView />
                </DataTemplate>
                <DataTemplate DataType="vm:LocalModelsViewModel">
                    <v:LocalModelsView />
                </DataTemplate>
                <DataTemplate DataType="vm:QuantizeViewModel">
                    <v:QuantizeView />
                </DataTemplate>
                <DataTemplate DataType="vm:AdaptiveQuantizeViewModel">
                    <v:AdaptiveQuantizeView />
                </DataTemplate>
                <DataTemplate DataType="vm:PerplexityViewModel">
                    <v:PerplexityView />
                </DataTemplate>
                <DataTemplate DataType="vm:KlDivergenceViewModel">
                    <v:KlDivergenceView />
                </DataTemplate>
                <DataTemplate DataType="vm:HellaswagViewModel">
                    <v:HellaswagView />
                </DataTemplate>
                <DataTemplate DataType="vm:ImatrixViewModel">
                    <v:ImatrixView />
                </DataTemplate>
                <DataTemplate DataType="vm:ControlVectorViewModel">
                    <v:ControlVectorView />
                </DataTemplate>
                <DataTemplate DataType="vm:GgufEditorViewModel">
                    <v:GgufEditorView />
                </DataTemplate>
                <DataTemplate DataType="vm:ShardingViewModel">
                    <v:ShardingView />
                </DataTemplate>
                <DataTemplate DataType="vm:HfConvertViewModel">
                    <v:HfConvertView />
                </DataTemplate>
                <DataTemplate DataType="vm:LoraMergeViewModel">
                    <v:LoraMergeView />
                </DataTemplate>
                <DataTemplate DataType="vm:RoadmapViewModel">
                    <v:RoadmapView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
        </DockPanel>
    </Grid>
    </DockPanel>
</Window>
