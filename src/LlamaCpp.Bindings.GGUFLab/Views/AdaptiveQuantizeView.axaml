<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             xmlns:v="using:LlamaCpp.Bindings.GGUFLab.Views"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.AdaptiveQuantizeView"
             x:DataType="vm:AdaptiveQuantizeViewModel">

    <DockPanel Margin="24,18">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Footer: progress, lightboard, status + log -->
        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto,Auto,140" Margin="0,12,0,0">
            <ProgressBar Grid.Row="0"
                         Minimum="0"
                         Maximum="{Binding SweepProgressTotal}"
                         Value="{Binding SweepProgressCurrent}"
                         IsVisible="{Binding IsRunning}"
                         Height="4"
                         Margin="0,0,0,6" />

            <!-- Lightboard: per-candidate chip strip for the tensor in flight.
                 Pending = dim, active phase = accent, done = green tick + MSE. -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,6"
                    Margin="0,0,0,6"
                    IsVisible="{Binding CandidateChips.Count}">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <TextBlock Grid.Column="0"
                                   Text="Tensor:" Opacity="0.6" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentTensorName}"
                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                   FontWeight="Medium"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding CurrentSubStatus}"
                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                   FontSize="11"
                                   Opacity="0.65"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding CandidateChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:AdaptiveQuantizeViewModel+CandidateChip">
                                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="8,3"
                                        Margin="0,2,6,2">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Setter Property="Background" Value="{DynamicResource SystemAltLowColor}" />
                                        </Style>
                                    </Border.Styles>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding StateGlyph}"
                                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                   FontSize="11"
                                                   Width="22"
                                                   TextAlignment="Center"
                                                   Opacity="0.85" />
                                        <TextBlock Text="{Binding Type}"
                                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                   FontWeight="SemiBold"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding MseText}"
                                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                   FontSize="11"
                                                   Opacity="0.65"
                                                   IsVisible="{Binding IsDone}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="{Binding StatusLine}"
                       Margin="0,0,0,6"
                       Opacity="0.85" />
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="{DynamicResource SystemAltLowColor}">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogText}"
                                         FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                         FontSize="12"
                                         Padding="10,8"
                                         TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Form -->
        <ScrollViewer>
            <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">

                <!-- File pickers -->
                <Grid ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Input GGUF" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="0">
                        <TextBox Text="{Binding InputPath}"
                                 PlaceholderText="Path to source .gguf" />
                        <v:RemedyCard />
                    </StackPanel>
                    <Button   Grid.Row="0" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseInput" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Imatrix" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="0">
                        <TextBox Text="{Binding ImatrixPath}"
                                 PlaceholderText="(optional) imatrix .gguf — column-importance weighting" />
                        <v:BuildImatrixRemedyCard />
                    </StackPanel>
                    <Button   Grid.Row="1" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseImatrix" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Base ftype" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              ItemsSource="{Binding AvailableFileTypes}"
                              SelectedItem="{Binding BaseFileType, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              ToolTip.Tip="Fallback ftype for tensors the recipe doesn't cover (1-D norms, etc.)" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Output GGUF" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding OutputPath}"
                              PlaceholderText="Leave blank to derive from input + threshold" />
                    <Button   Grid.Row="3" Grid.Column="2" Content="Browse…"
                              Click="OnBrowseOutput" />
                </Grid>

                <!-- Sweep controls -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Run sensitivity sweep"
                            Command="{Binding MeasureCommand}"
                            IsEnabled="{Binding IsIdle}"
                            Classes="accent" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}" />
                    <Button Content="Save scores…"
                            Click="OnSaveScores"
                            IsEnabled="{Binding HasScores}" />
                    <Button Content="Load scores…"
                            Click="OnLoadScores"
                            IsEnabled="{Binding IsIdle}" />
                </StackPanel>

                <!-- Threshold slider + recipe summary -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding HasScores}">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="120,*,80,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Threshold τ" VerticalAlignment="Center" />
                            <Slider   Grid.Column="1"
                                      Minimum="0.001" Maximum="0.20"
                                      SmallChange="0.001" LargeChange="0.01"
                                      Value="{Binding Threshold, Mode=TwoWay}" />
                            <TextBox  Grid.Column="2"
                                      Text="{Binding Threshold, Mode=TwoWay, StringFormat=F3}"
                                      VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding AverageBitsPerElementText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace" />
                        </Grid>
                        <TextBlock FontSize="11" Opacity="0.7">
                            <Run Text="{Binding RecipeRows.Count}" />
                            <Run Text=" tensors covered;" />
                            <Run Text="{Binding ExceededCount}" />
                            <Run Text=" exceeded τ (fell back to lowest-MSE candidate)." />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Recipe preview -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        IsVisible="{Binding HasScores}"
                        Height="280">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top"
                              ColumnDefinitions="3*,80,60,90,80"
                              ColumnSpacing="14"
                              Margin="14,8,14,4">
                            <TextBlock Grid.Column="0" Text="Tensor"   FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                            <TextBlock Grid.Column="1" Text="Type"     FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="bpw"      FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                            <TextBlock Grid.Column="3" Text="rel MSE"  FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                            <TextBlock Grid.Column="4" Text=""         FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                        </Grid>
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding RecipeRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:AdaptiveQuantizeViewModel+RecipeRow">
                                        <Grid ColumnDefinitions="3*,80,60,90,80"
                                              ColumnSpacing="14"
                                              Margin="14,3">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TensorName}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ChosenType}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BitsPerElementText}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12"
                                                       Opacity="0.75" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding RelativeMseText}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12"
                                                       Opacity="0.75" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding FlagText}"
                                                       FontSize="11"
                                                       Foreground="#d49a3a" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Apply controls -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Content="Save recipe…"
                            Click="OnSaveRecipe"
                            IsEnabled="{Binding HasScores}" />
                    <Button Content="Apply recipe to GGUF"
                            Command="{Binding ApplyCommand}"
                            IsEnabled="{Binding HasScores}"
                            Classes="accent" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
