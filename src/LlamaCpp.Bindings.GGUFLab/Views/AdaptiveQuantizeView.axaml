<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             xmlns:v="using:LlamaCpp.Bindings.GGUFLab.Views"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.AdaptiveQuantizeView"
             x:DataType="vm:AdaptiveQuantizeViewModel">

    <DockPanel Margin="24,18">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Footer: progress + status + log -->
        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto,Auto,140" Margin="0,12,0,0">
            <ProgressBar Grid.Row="0"
                         Minimum="0" Maximum="1"
                         Value="{Binding QuantizeProgressFraction}"
                         IsVisible="{Binding IsRunning}"
                         Height="4"
                         Margin="0,0,0,6" />
            <TextBlock Grid.Row="1"
                       Text="{Binding CurrentTensorLine}"
                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                       FontSize="11"
                       Opacity="0.65"
                       Margin="0,0,0,4"
                       TextTrimming="CharacterEllipsis"
                       IsVisible="{Binding IsRunning}" />
            <TextBlock Grid.Row="2"
                       Text="{Binding StatusLine}"
                       Margin="0,0,0,6"
                       Opacity="0.85" />
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="{DynamicResource SystemAltLowColor}">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogText}"
                                         FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                         FontSize="12"
                                         Padding="10,8"
                                         TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Form -->
        <ScrollViewer>
            <StackPanel Spacing="14" MaxWidth="900" HorizontalAlignment="Stretch">

                <!-- File pickers -->
                <Grid ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Input GGUF" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="0">
                        <TextBox Text="{Binding InputPath}"
                                 PlaceholderText="Path to source .gguf (F16 or already-quantized)" />
                        <v:RemedyCard />
                    </StackPanel>
                    <Button   Grid.Row="0" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseInput" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Imatrix" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="0">
                        <TextBox Text="{Binding ImatrixPath}"
                                 PlaceholderText="(optional) imatrix .gguf — column-importance weighting" />
                        <v:BuildImatrixRemedyCard />
                    </StackPanel>
                    <Button   Grid.Row="1" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseImatrix" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Profile" VerticalAlignment="Top" Margin="0,6,0,0" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                        <TextBox Text="{Binding ProfilePath}"
                                 PlaceholderText="(blank → auto-match by arch+size from data/profiles/)" />
                        <TextBlock Text="{Binding ProfileResolutionLine}"
                                   FontSize="11"
                                   Opacity="0.7"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Button   Grid.Row="2" Grid.Column="2" Content="Browse…"
                              VerticalAlignment="Top"
                              Click="OnBrowseProfile" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Output GGUF" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding OutputPath}"
                              PlaceholderText="Leave blank to derive from input + target bpw" />
                    <Button   Grid.Row="3" Grid.Column="2" Content="Browse…"
                              Click="OnBrowseOutput" />
                </Grid>

                <!-- Profile summary (when loaded) -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding HasProfile}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Profile" FontWeight="SemiBold" FontSize="11" Opacity="0.7" />
                        <TextBlock Text="{Binding ProfileSummaryLine}"
                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ProfileDetailLine}"
                                   FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                   FontSize="11"
                                   Opacity="0.7"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Target bpw -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        IsVisible="{Binding HasProfile}">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="120,*,90,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Target bpw" VerticalAlignment="Center" />
                            <Slider   Grid.Column="1"
                                      Minimum="2.5" Maximum="8.5"
                                      SmallChange="0.05" LargeChange="0.5"
                                      Value="{Binding TargetBitsPerElement, Mode=TwoWay}" />
                            <TextBox  Grid.Column="2"
                                      Text="{Binding TargetBitsPerElement, Mode=TwoWay, StringFormat=F2}"
                                      VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding TargetBpwText}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                       Opacity="0.7" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="120,0,0,0">
                            <TextBlock Text="Presets:" Opacity="0.6" VerticalAlignment="Center" FontSize="11" />
                            <Button Content="Q4_K_M (4.95)" Click="OnPresetQ4KM" Padding="8,2" />
                            <Button Content="Q5_K_M (5.50)" Click="OnPresetQ5KM" Padding="8,2" />
                            <Button Content="Q6_K (6.56)"   Click="OnPresetQ6K"  Padding="8,2" />
                            <Button Content="Q8_0 (8.50)"   Click="OnPresetQ80"  Padding="8,2" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Advanced (collapsed by default) -->
                <Expander Header="Advanced recipe options" IsExpanded="False"
                          IsVisible="{Binding HasProfile}">
                    <StackPanel Spacing="10" Margin="0,8,0,0">
                        <Grid ColumnDefinitions="200,*,90" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Min predicted gain (PPL)" VerticalAlignment="Center"
                                       ToolTip.Tip="Snap-to-stock threshold. If the recipe's predicted PPL gain over stock-equivalent is below this, the recipe collapses to stock. 0 disables." />
                            <Slider   Grid.Column="1" Minimum="0.0" Maximum="1.0"
                                      SmallChange="0.05" LargeChange="0.1"
                                      Value="{Binding MinPredictedGainPpl, Mode=TwoWay}" />
                            <TextBox  Grid.Column="2"
                                      Text="{Binding MinPredictedGainPpl, Mode=TwoWay, StringFormat=F2}"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="200,*,90" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Min PPL gain per bpw" VerticalAlignment="Center"
                                       ToolTip.Tip="Efficiency floor. A promotion is only taken when its predicted PPL gain divided by added bpw exceeds this." />
                            <Slider   Grid.Column="1" Minimum="0.0" Maximum="0.5"
                                      SmallChange="0.01" LargeChange="0.05"
                                      Value="{Binding MinPplGainPerBpw, Mode=TwoWay}" />
                            <TextBox  Grid.Column="2"
                                      Text="{Binding MinPplGainPerBpw, Mode=TwoWay, StringFormat=F2}"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="200,*,90" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="Size scaling exponent" VerticalAlignment="Center"
                                       ToolTip.Tip="Exponent on (target_params/source_params) when projecting profile coefficients to a different-sized target. 1.0 = linear (safe over-estimate)." />
                            <Slider   Grid.Column="1" Minimum="0.0" Maximum="1.5"
                                      SmallChange="0.05" LargeChange="0.1"
                                      Value="{Binding SizeScalingExponent, Mode=TwoWay}" />
                            <TextBox  Grid.Column="2"
                                      Text="{Binding SizeScalingExponent, Mode=TwoWay, StringFormat=F2}"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <CheckBox Content="Apply stock baseline (Q4_K_M-style per-layer protection)"
                                  IsChecked="{Binding ApplyStockBaseline, Mode=TwoWay}"
                                  ToolTip.Tip="Treats llama.cpp's hand-tuned per-layer protection table as a hard floor: recipe can promote above it but never demote below. Recommended on." />
                        <CheckBox Content="Use per-tensor data (when present) to demote individual tensors"
                                  IsChecked="{Binding UsePerTensorData, Mode=TwoWay}"
                                  ToolTip.Tip="When the profile has per-layer ablation data, demote tensors below the category-level pick where the per-tensor sensitivity is below the category average. Demote-only — never promotes. Requires per-layer profile data; ignored when only per-category data exists." />
                    </StackPanel>
                </Expander>

                <!-- Apply-time rails (warnings + blocks) -->
                <Border BorderBrush="#d49a3a"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        IsVisible="{Binding HasAnyRail}">
                    <ItemsControl ItemsSource="{Binding Rails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:AdaptiveQuantizeViewModel+RailMessage">
                                <Grid ColumnDefinitions="20,*" Margin="0,2">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Glyph}"
                                               FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                               FontSize="13"
                                               VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Recipe summary + preview -->
                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,10"
                        IsVisible="{Binding HasRecipe}">
                    <TextBlock Text="{Binding RecipeSummaryLine}"
                               FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </Border>

                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1"
                        CornerRadius="4"
                        IsVisible="{Binding HasRecipe}"
                        Height="280">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top"
                              ColumnDefinitions="3*,80,60,90"
                              ColumnSpacing="14"
                              Margin="14,8,14,4">
                            <TextBlock Grid.Column="0" Text="Tensor"  FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                            <TextBlock Grid.Column="1" Text="Type"    FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="bpw"     FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                            <TextBlock Grid.Column="3" Text="pred ΔPPL" FontWeight="SemiBold" Opacity="0.7" FontSize="11" />
                        </Grid>
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding RecipeRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:AdaptiveQuantizeViewModel+RecipeRow">
                                        <Grid ColumnDefinitions="3*,80,60,90"
                                              ColumnSpacing="14"
                                              Margin="14,3">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TensorName}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ChosenType}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BitsPerElementText}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12"
                                                       Opacity="0.75" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding PredictedDeltaPplText}"
                                                       FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                                       FontSize="12"
                                                       Opacity="0.75" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Content="Save recipe…"
                            Click="OnSaveRecipe"
                            IsEnabled="{Binding HasRecipe}" />
                    <Button Content="Quantize"
                            Command="{Binding QuantizeCommand}"
                            IsEnabled="{Binding CanQuantize}"
                            Classes="accent" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
