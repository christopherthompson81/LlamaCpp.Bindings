<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.HellaswagView"
             x:DataType="vm:HellaswagViewModel">

    <DockPanel Margin="24,18">
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
        </StackPanel>

        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto,Auto,*" Margin="0,12,0,0">
            <TextBlock Grid.Row="0" Text="{Binding StatusLine}" Margin="0,0,0,4" Opacity="0.85" />
            <ProgressBar Grid.Row="1" Value="{Binding ProgressFraction}"
                         Minimum="0" Maximum="1" Height="4" Margin="0,0,0,8" />
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource SystemAccentColorLight2}"
                    BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,8"
                    IsVisible="{Binding ResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <SelectableTextBlock Text="{Binding ResultText}"
                                     FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                     FontSize="12" />
            </Border>
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1" CornerRadius="4"
                    MinHeight="120" Background="{DynamicResource SystemAltLowColor}">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogText}"
                                         FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                         FontSize="12" Padding="10,8" TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <ScrollViewer>
            <StackPanel Spacing="14" MaxWidth="780" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Model GGUF" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding ModelPath}"
                              PlaceholderText="Path to a .gguf model" />
                    <Button   Grid.Row="0" Grid.Column="2" Content="Browse…" Click="OnBrowseModel" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Dataset file" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding DatasetPath}"
                              PlaceholderText="hellaswag_val_full.txt — or click Load standard…" />
                    <Button   Grid.Row="1" Grid.Column="2" Content="Browse…" Click="OnBrowseDataset" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Load standard HellaSwag dataset"
                            Command="{Binding LoadStandardDatasetCommand}"
                            ToolTip.Tip="Fetch (or read from cache) the canonical 10042-task validation set." />
                    <TextBlock Text="~10 K tasks (~5 MB). Cached after first fetch."
                               VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                </StackPanel>

                <Expander Header="Advanced options">
                    <StackPanel Spacing="10" Margin="0,8,0,0">
                        <Grid ColumnDefinitions="160,Auto" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Max tasks (0 = all)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="0" Grid.Column="1"
                                           Value="{Binding MaxTasks, Mode=TwoWay}"
                                           Minimum="0" Maximum="10042" Increment="100"
                                           FormatString="0" Width="140" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Context size (tokens)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="1" Grid.Column="1"
                                           Value="{Binding ContextSize, Mode=TwoWay}"
                                           Minimum="64" Maximum="4096" Increment="128"
                                           FormatString="0" Width="140" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="GPU layers (-1 = all)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                           Value="{Binding GpuLayerCount, Mode=TwoWay}"
                                           Minimum="-1" Maximum="999" Increment="1"
                                           FormatString="0" Width="140" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Threads (-1 = default)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="3" Grid.Column="1"
                                           Value="{Binding ThreadCount, Mode=TwoWay}"
                                           Minimum="-1" Maximum="256" Increment="1"
                                           FormatString="0" Width="140" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1" CornerRadius="4" Padding="14,10">
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12">
                        <Run Text="Note: V1 scores each candidate via a fresh full-sequence decode, so a 1000-task run with a 0.6B model takes a few minutes on CPU; the full 10042-task set takes proportionally longer. " />
                        <Run Text="acc_norm is the standard reported metric (length-normalized argmax)." />
                    </TextBlock>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Content="Run" Command="{Binding RunCommand}"
                            IsEnabled="{Binding IsIdle}" Classes="accent" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
