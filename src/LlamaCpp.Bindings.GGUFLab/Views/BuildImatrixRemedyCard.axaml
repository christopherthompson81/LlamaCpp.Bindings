<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.BuildImatrixRemedyCard"
             x:DataType="vm:ToolPageViewModel"
             IsVisible="{Binding ShowBuildImatrixRemedy}">

    <!--
        Info-styled remedy card for tools that take an optional imatrix
        sidecar. Color is deliberately info-blue rather than the warn-amber
        of the safetensors-conversion card so the user can tell at a glance
        whether a remedy is "blocked, fix this" vs "optional, this would
        improve quality".
    -->
    <Border Background="#332563EB"
            BorderBrush="#2563EB"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10,8"
            Margin="0,4,0,0">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
            <Viewbox Grid.Column="0"
                     Width="20" Height="20"
                     VerticalAlignment="Center">
                <Path Data="{StaticResource BriefcaseMedicalIcon}"
                      Stroke="#2563EB"
                      StrokeThickness="2"
                      StrokeLineCap="Round"
                      StrokeJoin="Round" />
            </Viewbox>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="No imatrix yet for this model."
                           FontWeight="SemiBold"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <TextBlock Text="An importance matrix gives the quantizer column-wise weighting and usually improves the result. Optional, but cheap to generate."
                           FontSize="11"
                           Opacity="0.8"
                           TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="2"
                    Content="Build imatrix"
                    Command="{Binding RemedyBuildImatrixCommand}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Switch to the Imatrix tool with this model preloaded. The result lands next to the model and auto-fills here on return." />
        </Grid>
    </Border>
</UserControl>
