<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.RoadmapView"
             x:DataType="vm:RoadmapViewModel">

    <ScrollViewer>
        <StackPanel Margin="24,18" Spacing="14" MaxWidth="780" HorizontalAlignment="Stretch">
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
            </StackPanel>

            <Border BorderBrush="{DynamicResource SystemAccentColorLight1}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14,10"
                    Background="{DynamicResource SystemAccentColorLight3}">
                <TextBlock Text="Not implemented in V1 — see below for the rationale and the next steps."
                           FontWeight="Medium"
                           TextWrapping="Wrap" />
            </Border>

            <StackPanel Spacing="6">
                <TextBlock Text="Why it's deferred" FontWeight="SemiBold" Opacity="0.85" />
                <TextBlock Text="{Binding Rationale}"
                           TextWrapping="Wrap"
                           LineHeight="20" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Next steps" FontWeight="SemiBold" Opacity="0.85" />
                <SelectableTextBlock Text="{Binding NextSteps}"
                                     FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                     FontSize="12"
                                     TextWrapping="Wrap" />
            </StackPanel>

            <Button Content="Run" IsEnabled="False" Width="80" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
