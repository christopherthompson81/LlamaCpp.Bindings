<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFLab.ViewModels"
             x:Class="LlamaCpp.Bindings.GGUFLab.Views.LoraMergeView"
             x:DataType="vm:LoraMergeViewModel">

    <DockPanel Margin="24,18">
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
        </StackPanel>

        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto,Auto,*" Margin="0,12,0,0">
            <TextBlock Grid.Row="0" Text="{Binding StatusLine}" Margin="0,0,0,4" Opacity="0.85" />
            <ProgressBar Grid.Row="1" Value="{Binding ProgressFraction}"
                         Minimum="0" Maximum="1" Height="4" Margin="0,0,0,8" />
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource SystemAccentColorLight2}"
                    BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,8"
                    IsVisible="{Binding ResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <SelectableTextBlock Text="{Binding ResultText}"
                                     FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                     FontSize="12" />
            </Border>
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1" CornerRadius="4"
                    MinHeight="120" Background="{DynamicResource SystemAltLowColor}">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogText}"
                                         FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                         FontSize="12" Padding="10,8" TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <ScrollViewer>
            <StackPanel Spacing="14" MaxWidth="780" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Base model" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding BasePath}"
                              PlaceholderText="Path to base GGUF (F32/F16/BF16)" />
                    <Button   Grid.Row="0" Grid.Column="2" Content="Browse…" Click="OnBrowseBase" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="LoRA adapter" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding AdapterPath}"
                              PlaceholderText="Path to LoRA adapter GGUF" />
                    <Button   Grid.Row="1" Grid.Column="2" Content="Browse…" Click="OnBrowseAdapter" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Output GGUF" VerticalAlignment="Center" />
                    <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding OutputPath}"
                              PlaceholderText="Leave blank to derive from base name" />
                    <Button   Grid.Row="2" Grid.Column="2" Content="Browse…" Click="OnBrowseOutput" />
                </Grid>

                <Grid ColumnDefinitions="120,*" ColumnSpacing="10" RowDefinitions="Auto,Auto" RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Adapter scale" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                   Value="{Binding AdapterScale, Mode=TwoWay}"
                                   Minimum="-10" Maximum="10" Increment="0.1"
                                   FormatString="F2" Width="120" HorizontalAlignment="Left"
                                   ToolTip.Tip="Multiplier applied on top of the adapter's own alpha/rank scaling. Default 1.0." />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Output type" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding AvailableOutputTypes}"
                              SelectedItem="{Binding OutputType, Mode=TwoWay}"
                              Width="120" HorizontalAlignment="Left" />
                </Grid>

                <Border BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1" CornerRadius="4" Padding="14,10">
                    <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12">
                        <Run Text="V1 supports F32 / F16 / BF16 base models. Quantized base models will be rejected — the conventional workflow is merge → quantize, so run the merge before quantizing." />
                    </TextBlock>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Content="Run" Command="{Binding RunCommand}"
                            IsEnabled="{Binding IsIdle}" Classes="accent" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
