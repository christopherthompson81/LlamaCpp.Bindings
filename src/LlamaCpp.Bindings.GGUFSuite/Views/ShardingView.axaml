<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LlamaCpp.Bindings.GGUFSuite.ViewModels"
             x:Class="LlamaCpp.Bindings.GGUFSuite.Views.ShardingView"
             x:DataType="vm:ShardingViewModel">

    <DockPanel Margin="24,18">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,18">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Opacity="0.65" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Footer: status + result + log -->
        <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,Auto,Auto,*" Margin="0,12,0,0">
            <TextBlock Grid.Row="0" Text="{Binding StatusLine}" Margin="0,0,0,4" Opacity="0.85" />
            <ProgressBar Grid.Row="1" Value="{Binding ProgressFraction}"
                         Minimum="0" Maximum="1" Height="4" Margin="0,0,0,8" />
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource SystemAccentColorLight2}"
                    BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,8"
                    IsVisible="{Binding ResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <SelectableTextBlock Text="{Binding ResultText}"
                                     FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                     FontSize="12" />
            </Border>
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1" CornerRadius="4"
                    MinHeight="120" Background="{DynamicResource SystemAltLowColor}">
                <ScrollViewer>
                    <SelectableTextBlock Text="{Binding LogText}"
                                         FontFamily="Cascadia Mono, Menlo, Consolas, monospace"
                                         FontSize="12" Padding="10,8" TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Form -->
        <ScrollViewer>
            <StackPanel Spacing="14" MaxWidth="780" HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="120,*" ColumnSpacing="10">
                    <TextBlock Grid.Column="0" Text="Mode" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableModes}"
                              SelectedItem="{Binding Mode, Mode=TwoWay}"
                              Width="160" HorizontalAlignment="Left" />
                </Grid>

                <!-- Split-mode form -->
                <StackPanel Spacing="14" IsVisible="{Binding IsSplitMode}">
                    <Grid ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Source GGUF" VerticalAlignment="Center" />
                        <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding SplitInputPath}"
                                  PlaceholderText="Input model.gguf to split" />
                        <Button   Grid.Row="0" Grid.Column="2" Content="Browse…"
                                  Click="OnBrowseSplitInput" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Output prefix" VerticalAlignment="Center" />
                        <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding SplitOutputPrefix}"
                                  PlaceholderText="Path prefix (no extension); shards expand to &lt;prefix&gt;-NNNNN-of-NNNNN.gguf" />
                        <Button   Grid.Row="1" Grid.Column="2" Content="Browse…"
                                  Click="OnBrowseSplitOutputPrefix" />
                    </Grid>

                    <Grid ColumnDefinitions="120,*" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="Limit by" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <ComboBox ItemsSource="{Binding AvailableLimitModes}"
                                      SelectedItem="{Binding SplitLimitMode, Mode=TwoWay}"
                                      Width="120" />
                            <NumericUpDown Value="{Binding MaxTensorsPerShard, Mode=TwoWay}"
                                           Minimum="1" Maximum="100000" Increment="32"
                                           FormatString="0" Width="120"
                                           IsVisible="{Binding IsTensorsLimitMode}" />
                            <NumericUpDown Value="{Binding MaxMegabytesPerShard, Mode=TwoWay}"
                                           Minimum="1" Maximum="65536" Increment="256"
                                           FormatString="0 'MB'" Width="120"
                                           IsVisible="{Binding IsBytesLimitMode}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Merge-mode form -->
                <StackPanel Spacing="14" IsVisible="{Binding IsMergeMode}">
                    <Grid ColumnDefinitions="120,*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="First shard" VerticalAlignment="Center" />
                        <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding MergeFirstShardPath}"
                                  PlaceholderText="*-00001-of-NNNNN.gguf — siblings auto-located" />
                        <Button   Grid.Row="0" Grid.Column="2" Content="Browse…"
                                  Click="OnBrowseMergeFirst" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Output GGUF" VerticalAlignment="Center" />
                        <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding MergeOutputPath}"
                                  PlaceholderText="Single-file output" />
                        <Button   Grid.Row="1" Grid.Column="2" Content="Browse…"
                                  Click="OnBrowseMergeOutput" />
                    </Grid>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button Content="Run"    Command="{Binding RunCommand}"
                            IsEnabled="{Binding IsIdle}" Classes="accent" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
