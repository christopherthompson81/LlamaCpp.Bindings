{
  "$schema": "sampling-profiles.schema.json",
  "description": "Publisher-recommended sampler settings per model family. First match wins — list more specific entries before more general ones. Match keys: 'architecture' (GGUF general.architecture, case-insensitive), 'namePattern' (regex against GGUF general.name, case-insensitive). Missing match keys wildcard. Every entry should carry a 'source' field so maintenance can sanity-check against the original recommendation.",
  "profiles": [
    {
      "id": "qwen3-thinking",
      "match": { "architecture": "qwen3", "namePattern": "(?i)thinking|reasoning|reasoner|qwq" },
      "sampling": {
        "temperature": 0.6,
        "topP": 0.95,
        "topK": 20,
        "minP": 0.0,
        "penaltyRepeat": 1.0
      },
      "notes": "Qwen team recommends these for Qwen3 thinking mode / QwQ.",
      "source": "https://qwenlm.github.io/blog/qwen3/"
    },
    {
      "id": "qwen3",
      "match": { "architecture": "qwen3" },
      "sampling": {
        "temperature": 0.7,
        "topP": 0.8,
        "topK": 20,
        "minP": 0.0,
        "penaltyRepeat": 1.0
      },
      "notes": "Qwen3 non-thinking / instruct defaults per Qwen blog.",
      "source": "https://qwenlm.github.io/blog/qwen3/"
    },
    {
      "id": "qwen3-moe-thinking",
      "match": { "architecture": "qwen3moe", "namePattern": "(?i)thinking|reasoning|reasoner" },
      "sampling": {
        "temperature": 0.6,
        "topP": 0.95,
        "topK": 20,
        "minP": 0.0,
        "penaltyRepeat": 1.0
      },
      "notes": "Qwen3 MoE thinking (e.g. Qwen3-30B-A3B-Thinking) — same recipe as dense Qwen3 thinking.",
      "source": "https://qwenlm.github.io/blog/qwen3/"
    },
    {
      "id": "qwen3-moe",
