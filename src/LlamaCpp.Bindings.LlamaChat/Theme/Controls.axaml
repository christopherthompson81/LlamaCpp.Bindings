<!--
    Control styles layered on top of FluentTheme. Adopts the tokens from
    Theme/Tokens.axaml to get shadcn/webui-like aesthetics: muted chrome,
    generous radii, lowercase density for UI chrome.

    Button variants match shadcn's six (default/destructive/outline/
    secondary/ghost/link), applied by Classes="primary|destructive|..." on
    the element. Default (no class) == primary.
  -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:a="using:Avalonia.Automation">

    <!-- ================================================================
         Base TextBlock conventions
         ================================================================ -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBase}" />
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}" />
    </Style>
    <Style Selector="TextBlock.xs">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
    </Style>
    <Style Selector="TextBlock.sm">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="{DynamicResource FontSize2xl}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXl}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h3">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeLg}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <!-- TextBlocks inside Buttons inherit the Button's Foreground rather
         than the global window Foreground. Without this, a plain <TextBlock
         Text="Load" /> inside a primary Button (near-white background in
         dark theme) renders near-white-on-near-white — invisible. The
         base `TextBlock` style above forces Foreground to the window-level
         resource, which is what breaks the Button's normal inheritance
         path; this override pulls it back. Explicit classes like `.muted`
         still win because they're more specific. -->
    <Style Selector="Button TextBlock">
        <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <Style Selector="TextBlock.section">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}" />
        <Setter Property="Margin" Value="0,10,0,4" />
    </Style>

    <!-- ================================================================
         Window
         ================================================================ -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBase}" />
    </Style>

    <!-- ================================================================
         Button — base (acts as "primary"/"default" shadcn variant)
         ================================================================ -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>
    <!-- Disabled: swap to Muted background + MutedForeground so the label text
         stays readable (opacity-dimming made dark-on-dark unreadable on
         Button base / destructive). The inner ContentPresenter targets the
         Fluent template so the setter reaches the actual rendered surface. -->
    <Style Selector="Button:disabled">
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}" />
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>

    <!-- Button.destructive -->
    <Style Selector="Button.destructive">
        <Setter Property="Background" Value="{DynamicResource Destructive}" />
        <Setter Property="Foreground" Value="{DynamicResource DestructiveForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
    </Style>
    <Style Selector="Button.destructive:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Destructive}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
    </Style>

    <!-- Button.outline -->
    <Style Selector="Button.outline">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>
    <Style Selector="Button.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Button.secondary -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource Secondary}" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Secondary}" />
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Secondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Secondary}" />
    </Style>

    <!-- Button.ghost — transparent until hover -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Button.link — inline text affordance -->
    <Style Selector="Button.link">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="4,2" />
    </Style>
    <Style Selector="Button.link:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="TextBlock.TextDecorations" Value="Underline" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Size modifiers — compose with any variant -->
    <Style Selector="Button.sm">
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeightSm}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
    </Style>
    <Style Selector="Button.lg">
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeightLg}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBase}" />
    </Style>

    <!-- ================================================================
         TextBox
         ================================================================ -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Ring}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Foreground}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Ring}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>
    <Style Selector="TextBox:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>
    <!-- Form-validation invalid state: red border. Toggle via Classes.invalid
         bound to an IsXxxInvalid bool on the owning view model. Works for
         both unfocused and focused states; :focus.invalid still reads red. -->
    <Style Selector="TextBox.invalid /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
    </Style>
    <Style Selector="TextBox.invalid:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>

    <!-- ================================================================
         ComboBox
         ================================================================ -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>

    <!-- ================================================================
         NumericUpDown
         ================================================================ -->
    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>

    <!-- ================================================================
         CheckBox
         ================================================================ -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="Padding" Value="8,0,0,0" />
    </Style>

    <!-- ================================================================
         ToolTip — shadcn-style dark pill, theme-independent. We don't reuse
         the theme tokens because that couples the tooltip bg to whatever
         Foreground ends up being in each theme (and inverting the theme
         tokens produced white-on-white inside message action-bar tooltips,
         where the parent Foreground inherits down through the popup).
         Hardcoding the dark-pill pair keeps contrast consistent everywhere.
         The TextBlock.Foreground attached-property setter forces the color
         on the ContentPresenter's generated TextBlock regardless of which
         TextBlock.Foreground value would otherwise inherit from the owner.
         ================================================================ -->
    <Style Selector="ToolTip">
        <Setter Property="Background" Value="#18181B" />
        <Setter Property="Foreground" Value="#FAFAFA" />
        <Setter Property="BorderBrush" Value="#27272A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
    </Style>
    <Style Selector="ToolTip TextBlock">
        <Setter Property="Foreground" Value="#FAFAFA" />
    </Style>

    <!-- ================================================================
         ToggleButton.switch — shadcn-style animated switch
         Usage: <ToggleButton Classes="switch" IsChecked="..." Content="label" />
         A pill-shaped track with a sliding thumb; the label sits to the
         right of the track and binds to Content like a CheckBox. The
         Margin + Background transitions give the animated feel.
         ================================================================ -->
    <Style Selector="ToggleButton.switch">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" Name="Track"
                            Width="32" Height="18" CornerRadius="9"
                            VerticalAlignment="Center"
                            Background="{DynamicResource Muted}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15" />
                            </Transitions>
                        </Border.Transitions>
                        <Border Name="Knob" Width="12" Height="12" CornerRadius="6"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Margin="2,0,0,0"
                                Background="{DynamicResource Foreground}">
                            <Border.Transitions>
                                <Transitions>
                                    <ThicknessTransition Property="Margin" Duration="0:0:0.15" Easing="CubicEaseOut" />
                                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>
                    </Border>
                    <ContentPresenter Grid.Column="1"
                                     Content="{TemplateBinding Content}"
                                     ContentTemplate="{TemplateBinding ContentTemplate}"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center"
                                     TextBlock.Foreground="{TemplateBinding Foreground}"
                                     TextBlock.FontSize="{TemplateBinding FontSize}" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.switch:checked /template/ Border#Track">
        <Setter Property="Background" Value="{DynamicResource Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
    </Style>
    <Style Selector="ToggleButton.switch:checked /template/ Border#Knob">
        <Setter Property="Margin" Value="16,0,0,0" />
        <Setter Property="Background" Value="{DynamicResource PrimaryForeground}" />
    </Style>
    <Style Selector="ToggleButton.switch:pointerover /template/ Border#Track">
        <Setter Property="BorderBrush" Value="{DynamicResource Foreground}" />
    </Style>
    <Style Selector="ToggleButton.switch:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- ================================================================
         ListBox / ListBoxItem — used for profile list & messages
         ================================================================ -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
    </Style>

    <!-- ================================================================
         Menu + MenuItem — top bar
         ================================================================ -->
    <Style Selector="Menu">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuItem">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
    </Style>

    <!-- ================================================================
         Expander — reasoning panel
         ================================================================ -->
    <Style Selector="Expander">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>

    <!-- Reasoning card variant: full-width pill inside a bubble, muted
         background, rounded border, a bit of padding. The header's brain
         icon + label is supplied by the bubble template; Avalonia's built-in
         Expander chevron sits on the right, rotating on expand.
         The content has an Opacity transition for the expand animation —
         content size transitions would need a custom template; the opacity
         fade + the default layout transition is visually acceptable. -->
    <Style Selector="Expander.reasoning">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander.reasoning /template/ ToggleButton">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander.reasoning ContentPresenter#PART_ContentPresenter">
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <!-- ================================================================
         Composer pod — the rounded container around the compose TextBox.
         Holds the TextBox + overlaid + menu button + Send button so the
         three read as a single chip rather than three separate widgets.
         ================================================================ -->
    <Style Selector="Border.composer-pod">
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="MinHeight" Value="92" />
    </Style>
    <Style Selector="Border.composer-pod:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource Ring}" />
    </Style>

    <!-- ================================================================
         Reusable Border classes
         ================================================================ -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
        <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="Border.statusbar">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="12,4" />
    </Style>

    <!-- Message bubble classes -->
    <Style Selector="Border.bubble">
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,4" />
    </Style>
    <Style Selector="Border.bubble.user">
        <Setter Property="Background" Value="{DynamicResource UserBubble}" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="MaxWidth" Value="640" />
    </Style>
    <!-- User bubbles are dark-on-light-theme by design. TextBlocks inside
         would otherwise pick up the global Foreground (near-black in
         light theme) and render invisible on the dark bubble. Descendant
         selectors rebind to UserBubbleForeground — mirrors the
         Button TextBlock escape from the base TextBlock style. -->
    <Style Selector="Border.bubble.user TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource UserBubbleForeground}" />
    </Style>
    <Style Selector="Border.bubble.user SelectableTextBlock">
        <Setter Property="Foreground" Value="{DynamicResource UserBubbleForeground}" />
    </Style>
    <Style Selector="Border.bubble.assistant">
        <Setter Property="Background" Value="{DynamicResource AssistantBubble}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <!-- Tool-result bubbles: muted, compact, offset from the main convo flow
         so the eye can skim past them. Left-rail accent hints at "this was
         machine I/O, not a turn." -->
    <Style Selector="Border.bubble.tool">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1,1,1,1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="16,4,16,4" />
        <Setter Property="Opacity" Value="0.92" />
    </Style>
    <!-- Errored tool result: keep the muted fill so the content stays legible,
         but swap the border to Destructive and stretch it slightly so an
         at-a-glance scan of the transcript shows which tool calls failed. -->
    <Style Selector="Border.bubble.toolerror">
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Tool-call chip: compact pill shown above an assistant reply when the
         model invoked a tool. Visual shorthand for the full markup which
         lives in the model-facing content string. -->
    <Style Selector="Border.toolchip">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <!-- ================================================================
         Lucide icon rendering. A Path element with class="icon" picks up
         the standard stroke/cap/join settings that make a 24-unit
         lucide path scale cleanly to 16×16 at 2px equivalent stroke.

         Foreground binds to the current text colour, so icons adopt the
         surrounding element's tint (muted buttons, accent hovers, etc.)
         without per-icon overrides.
         ================================================================ -->
    <Style Selector="Path.icon">
        <Setter Property="Stroke" Value="{DynamicResource Foreground}" />
        <Setter Property="StrokeThickness" Value="2" />
        <Setter Property="StrokeLineCap" Value="Round" />
        <Setter Property="StrokeJoin" Value="Round" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="Uniform" />
    </Style>
    <Style Selector="Path.icon.xs">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="StrokeThickness" Value="2.2" />
    </Style>
    <Style Selector="Path.icon.sm">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
    </Style>
    <Style Selector="Path.icon.lg">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
    </Style>
    <!-- Icon inside a Button adopts the button's Foreground rather than
         the global Foreground — lets icon buttons keep correct contrast
         against primary/destructive/accent backgrounds. -->
    <Style Selector="Button Path.icon">
        <Setter Property="Stroke" Value="{Binding $parent[Button].Foreground}" />
    </Style>

    <!-- Icon-only button variant. Square aspect, centered content, no
         text padding. Base size matches .sm (28px) so it slots into
         existing bubble action bars without a layout shift. -->
    <Style Selector="Button.icon">
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.icon.sm">
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
    </Style>
    <Style Selector="Button.icon.lg">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
    </Style>

    <!-- ================================================================
         Message-bubble action bar (Copy/Edit/Retry/Continue/Delete).
         Hidden by default so the transcript reads as clean prose; fades
         in when the user hovers the bubble. The StackPanel always
         occupies its natural vertical space so the bubble doesn't
         jump-resize on pointer enter/leave.

         IsHitTestVisible gating prevents accidental clicks while the
         bar is invisible — important because the buttons' bounds are
         still laid out and would otherwise eat clicks meant for the
         text underneath.
         ================================================================ -->
    <Style Selector="StackPanel.actions">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
            </Transitions>
        </Setter>
    </Style>
    <!-- Reveal on bubble hover. Also on keyboard focus anywhere inside
         the bubble so Tab-navigation users can still reach the actions. -->
    <Style Selector="Border.bubble:pointerover StackPanel.actions">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="Border.bubble:focus-within StackPanel.actions">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <!-- Heightened accessibility mode: force the action bar always visible
         regardless of hover/focus, so every action is reachable without a
         pointer. Toggled by the AppSettings.HighAccessibilityMode setting
         which Classes.a11y-binds on the root Window. -->
    <Style Selector="Window.a11y StackPanel.actions">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <!-- Monospace boxed container for a tool result's text output. Reuses
         the same code-block tokens the markdown renderer uses for fenced
         code, so tool output reads at a glance as "machine output" rather
         than "prose." -->
    <Style Selector="Border.toolresult">
        <Setter Property="Background" Value="{DynamicResource CodeBackground}" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="Border.toolresult SelectableTextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource CodeForeground}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- ================================================================
         Toast notifications — each card is a Border.toast with a severity
         modifier class that picks its accent colour.
         ================================================================ -->
    <Style Selector="Border.toast">
        <Setter Property="BoxShadow" Value="0 4 16 0 #40000000" />
        <!-- LiveSetting=Polite means a screen reader announces the toast at
             its next natural pause. Errors escalate to Assertive below so
             they interrupt. -->
        <Setter Property="a:AutomationProperties.LiveSetting" Value="Polite" />
    </Style>
    <Style Selector="Border.toast.success">
        <Setter Property="BorderBrush" Value="#16A34A" />
    </Style>
    <Style Selector="Border.toast.warning">
        <Setter Property="BorderBrush" Value="#D97706" />
        <Setter Property="a:AutomationProperties.LiveSetting" Value="Assertive" />
    </Style>
    <Style Selector="Border.toast.error">
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
        <Setter Property="a:AutomationProperties.LiveSetting" Value="Assertive" />
    </Style>

    <!-- ================================================================
         Streaming cursor — a pulsing block character appended to the live
         tail of MarkdownView while the bubble has IsStreaming=true.
         ================================================================ -->
    <Style Selector="TextBlock.cursor">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="Opacity" Value="1" />
        <Style.Animations>
            <Animation Duration="0:0:1" IterationCount="Infinite">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Sidebar slide: MainWindow's sidebar Border toggles Classes.collapsed;
         Width animates via DoubleTransition defined inline on the Border. -->
    <Style Selector="Border.sidebar">
        <Setter Property="Width" Value="280" />
    </Style>
    <Style Selector="Border.sidebar.collapsed">
        <Setter Property="Width" Value="0" />
    </Style>

    <!-- Brain "thinking" pulse: applied to the reasoning-card header icon
         while the assistant is mid-generation. The Ring-coloured DropShadow
         gives a blue halo; the opacity cycle breathes it in and out so the
         user has a peripheral "model is still working" signal. -->
    <Style Selector="Path.brain-pulsing">
        <Setter Property="Effect">
            <DropShadowEffect Color="#60A5FA" BlurRadius="10" OffsetX="0" OffsetY="0" />
        </Setter>
        <Style.Animations>
            <Animation Duration="0:0:1.6" IterationCount="Infinite" Easing="SineEaseInOut">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.55" /></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
