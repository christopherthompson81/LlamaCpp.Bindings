<!--
    Control styles layered on top of FluentTheme. Adopts the tokens from
    Theme/Tokens.axaml to get shadcn/webui-like aesthetics: muted chrome,
    generous radii, lowercase density for UI chrome.

    Button variants match shadcn's six (default/destructive/outline/
    secondary/ghost/link), applied by Classes="primary|destructive|..." on
    the element. Default (no class) == primary.
  -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================
         Base TextBlock conventions
         ================================================================ -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBase}" />
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}" />
    </Style>
    <Style Selector="TextBlock.xs">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
    </Style>
    <Style Selector="TextBlock.sm">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="{DynamicResource FontSize2xl}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXl}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.h3">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeLg}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.section">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}" />
        <Setter Property="Margin" Value="0,10,0,4" />
    </Style>

    <!-- ================================================================
         Window
         ================================================================ -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBase}" />
    </Style>

    <!-- ================================================================
         Button — base (acts as "primary"/"default" shadcn variant)
         ================================================================ -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        <Setter Property="Opacity" Value="0.8" />
    </Style>
    <Style Selector="Button:disabled">
        <Setter Property="Opacity" Value="0.5" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <!-- Button.destructive -->
    <Style Selector="Button.destructive">
        <Setter Property="Background" Value="{DynamicResource Destructive}" />
        <Setter Property="Foreground" Value="{DynamicResource DestructiveForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
    </Style>
    <Style Selector="Button.destructive:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Destructive}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
    </Style>

    <!-- Button.outline -->
    <Style Selector="Button.outline">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>
    <Style Selector="Button.outline:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Button.secondary -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource Secondary}" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Secondary}" />
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Secondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Secondary}" />
    </Style>

    <!-- Button.ghost — transparent until hover -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Button.link — inline text affordance -->
    <Style Selector="Button.link">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="4,2" />
    </Style>
    <Style Selector="Button.link:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="TextBlock.TextDecorations" Value="Underline" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Size modifiers — compose with any variant -->
    <Style Selector="Button.sm">
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeightSm}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXs}" />
    </Style>
    <Style Selector="Button.lg">
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeightLg}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBase}" />
    </Style>

    <!-- ================================================================
         TextBox
         ================================================================ -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Ring}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Foreground}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource Ring}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>
    <Style Selector="TextBox:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- ================================================================
         ComboBox
         ================================================================ -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>

    <!-- ================================================================
         NumericUpDown
         ================================================================ -->
    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{DynamicResource Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="MinHeight" Value="{DynamicResource ControlHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>

    <!-- ================================================================
         CheckBox
         ================================================================ -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="Padding" Value="8,0,0,0" />
    </Style>

    <!-- ================================================================
         ListBox / ListBoxItem — used for profile list & messages
         ================================================================ -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
    </Style>

    <!-- ================================================================
         Menu + MenuItem — top bar
         ================================================================ -->
    <Style Selector="Menu">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuItem">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusSm}" />
    </Style>

    <!-- ================================================================
         Expander — reasoning panel
         ================================================================ -->
    <Style Selector="Expander">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
    </Style>

    <!-- ================================================================
         Reusable Border classes
         ================================================================ -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource Card}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
        <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="Border.statusbar">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="12,4" />
    </Style>

    <!-- Message bubble classes -->
    <Style Selector="Border.bubble">
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusLg}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,4" />
    </Style>
    <Style Selector="Border.bubble.user">
        <Setter Property="Background" Value="{DynamicResource UserBubble}" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="MaxWidth" Value="640" />
    </Style>
    <Style Selector="Border.bubble.assistant">
        <Setter Property="Background" Value="{DynamicResource AssistantBubble}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <!-- Tool-result bubbles: muted, compact, offset from the main convo flow
         so the eye can skim past them. Left-rail accent hints at "this was
         machine I/O, not a turn." -->
    <Style Selector="Border.bubble.tool">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1,1,1,1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="16,4,16,4" />
        <Setter Property="Opacity" Value="0.92" />
    </Style>

    <!-- Tool-call chip: compact pill shown above an assistant reply when the
         model invoked a tool. Visual shorthand for the full markup which
         lives in the model-facing content string. -->
    <Style Selector="Border.toolchip">
        <Setter Property="Background" Value="{DynamicResource Muted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,2" />
    </Style>

    <!-- Monospace boxed container for a tool result's text output. Reuses
         the same code-block tokens the markdown renderer uses for fenced
         code, so tool output reads at a glance as "machine output" rather
         than "prose." -->
    <Style Selector="Border.toolresult">
        <Setter Property="Background" Value="{DynamicResource CodeBackground}" />
        <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="Border.toolresult SelectableTextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource CodeFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource CodeForeground}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- ================================================================
         Toast notifications — each card is a Border.toast with a severity
         modifier class that picks its accent colour.
         ================================================================ -->
    <Style Selector="Border.toast">
        <Setter Property="BoxShadow" Value="0 4 16 0 #40000000" />
    </Style>
    <Style Selector="Border.toast.success">
        <Setter Property="BorderBrush" Value="#16A34A" />
    </Style>
    <Style Selector="Border.toast.warning">
        <Setter Property="BorderBrush" Value="#D97706" />
    </Style>
    <Style Selector="Border.toast.error">
        <Setter Property="BorderBrush" Value="{DynamicResource Destructive}" />
    </Style>

    <!-- ================================================================
         Streaming cursor — a pulsing block character appended to the live
         tail of MarkdownView while the bubble has IsStreaming=true.
         ================================================================ -->
    <Style Selector="TextBlock.cursor">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
        <Setter Property="Opacity" Value="1" />
        <Style.Animations>
            <Animation Duration="0:0:1" IterationCount="Infinite">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.2" /></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
