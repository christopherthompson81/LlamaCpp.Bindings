<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LlamaCpp.Bindings.LlamaChat.ViewModels"
        xmlns:v="using:LlamaCpp.Bindings.LlamaChat.Views"
        xmlns:m="using:LlamaCpp.Bindings.LlamaChat.Models"
        xmlns:a="using:Avalonia.Automation"
        mc:Ignorable="d"
        d:DesignWidth="960" d:DesignHeight="720"
        x:Class="LlamaCpp.Bindings.LlamaChat.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="Settings"
        Width="960" Height="720" MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Classes="panel" Padding="20,14">
            <TextBlock Text="Settings" Classes="h2" />
        </Border>

        <!-- Body: tabbed -->
        <TabControl Grid.Row="1" TabStripPlacement="Left" Margin="8,8,8,0">

            <!-- ===== Profiles ===== -->
            <TabItem Header="Profiles">
                <Grid RowDefinitions="Auto,*" Margin="8">

                    <!-- Top card: profile picker + CRUD actions. Horizontal
                         ListBox reads as a row of tabs; scroller kicks in
                         once there are more profiles than fit the width. -->
                    <Border Grid.Row="0" Classes="card">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="Profiles" Classes="section"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <ComboBox Grid.Column="1" Margin="0,0,12,0"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding SelectedProfile}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="vm:ProfileEditorViewModel">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                <Button Classes="sm outline" ToolTip.Tip="Add profile"
                                        Command="{Binding AddProfileCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Path Classes="icon xs" Data="{StaticResource IconPlus}" />
                                        <TextBlock Text="Add" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="sm outline" ToolTip.Tip="Duplicate profile"
                                        Command="{Binding DuplicateProfileCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Path Classes="icon xs" Data="{StaticResource IconCopy}" />
                                        <TextBlock Text="Duplicate" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="sm destructive" ToolTip.Tip="Delete profile"
                                        Command="{Binding DeleteProfileCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Path Classes="icon xs" Data="{StaticResource IconTrash}" />
                                        <TextBlock Text="Delete" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Bottom card: editor for the currently selected profile. -->
                    <Border Grid.Row="1" Margin="0,16,0,0" Classes="card">
                        <Grid RowDefinitions="*,Auto">
                            <ScrollViewer Grid.Row="0" Padding="0,0,8,0">
                                <ContentControl Content="{Binding SelectedProfile}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate DataType="vm:ProfileEditorViewModel">
                                            <v:ProfileEditorView />
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </ScrollViewer>
                            <StackPanel Grid.Row="1" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Margin="0,12,0,0" Spacing="6">
                                <Button Content="Reset sampling" Classes="sm outline"
                                        Command="{Binding ResetSamplerDefaultsCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ===== Display ===== -->
            <TabItem Header="Display">
                <Border Classes="card" Margin="8">
                    <StackPanel DataContext="{Binding AppSettings}" Spacing="14">
                        <TextBlock Text="Display" Classes="h3" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Theme" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="130,*">
                                <TextBlock Grid.Column="0" Text="Mode" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" SelectedItem="{Binding ThemeMode}">
                                    <ComboBox.Items>
                                        <m:AppThemeMode>Auto</m:AppThemeMode>
                                        <m:AppThemeMode>Light</m:AppThemeMode>
                                        <m:AppThemeMode>Dark</m:AppThemeMode>
                                    </ComboBox.Items>
                                </ComboBox>
                            </Grid>
                            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                                       Text="Auto follows your system's light/dark preference." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleButton Classes="switch" Content="Auto-scroll new messages"
                                          IsChecked="{Binding AutoScroll}" />
                            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                                       Text="Keep the chat pinned to the newest content as it streams. Turn off to scroll freely mid-response." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleButton Classes="switch" Content="Show message stats"
                                          IsChecked="{Binding ShowMessageStats}" />
                            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                                       Text="Token count and tokens-per-second shown under each assistant reply." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleButton Classes="switch" Content="Expand reasoning during streaming"
                                          IsChecked="{Binding ShowReasoningInProgress}" />
                            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                                       Text="Auto-open the &lt;think&gt; panel while a reply is mid-stream so you can watch the trace as it appears." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleButton Classes="switch" Content="Heightened accessibility mode"
                                          IsChecked="{Binding HighAccessibilityMode}" />
                            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                                       Text="Always-visible message action bar (no hover-to-reveal) so every action is reachable without a pointer." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleButton Classes="switch" Content="Auto-title new conversations"
                                          IsChecked="{Binding AutoTitleNewConversations}" />
                            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                                       Text="Derive a title from your first message when a new chat is still called &quot;New chat&quot;. You can still rename by hand." />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleButton Classes="switch" Content="Strip thinking from message history"
                                          IsChecked="{Binding StripThinkingFromHistory}" />
                            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                                       Text="Omit prior &lt;think&gt; blocks when sending conversation history back to the model. Off preserves chain-of-thought across turns at the cost of context budget." />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- ===== Tools / MCP ===== -->
            <TabItem Header="Tools / MCP">
                <ContentControl Content="{Binding McpSettings}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="vm:McpSettingsViewModel">
                            <v:McpSettingsView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>

            <!-- ===== Response format ===== -->
            <TabItem Header="Response format">
                <Grid RowDefinitions="Auto,*" Margin="8"
                      DataContext="{Binding SelectedProfile}">

                    <!-- Top card: profile reminder + mode dropdown -->
                    <Border Grid.Row="0" Classes="card">
                        <Grid ColumnDefinitions="Auto,*,Auto,180">
                            <TextBlock Grid.Column="0" Text="Profile"
                                       Classes="section" VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <ComboBox Grid.Column="1" Margin="0,0,16,0"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding $parent[Window].((vm:SettingsWindowViewModel)DataContext).Profiles}"
                                      SelectedItem="{Binding $parent[Window].((vm:SettingsWindowViewModel)DataContext).SelectedProfile}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="vm:ProfileEditorViewModel">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Column="2" Text="Mode"
                                       Classes="section" VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <ComboBox Grid.Column="3" HorizontalAlignment="Stretch"
                                      DataContext="{Binding SamplerPanel}"
                                      SelectedItem="{Binding ResponseFormat}">
                                <ComboBox.Items>
                                    <m:ResponseFormatMode>Off</m:ResponseFormatMode>
                                    <m:ResponseFormatMode>Json</m:ResponseFormatMode>
                                    <m:ResponseFormatMode>JsonSchema</m:ResponseFormatMode>
                                    <m:ResponseFormatMode>Gbnf</m:ResponseFormatMode>
                                </ComboBox.Items>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Bottom: side-by-side editor (left) + compiled preview (right). -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,16,0,0"
                          DataContext="{Binding SamplerPanel}">

                        <Border Grid.Column="0" Classes="card" Margin="0,0,8,0">
                            <Grid RowDefinitions="Auto,Auto,*">
                                <TextBlock Grid.Row="0" Text="Schema / Grammar"
                                           Classes="section" Margin="0" />
                                <TextBlock Grid.Row="1" Classes="xs muted"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"
                                           Text="{Binding ResponseFormatTextHint}"
                                           IsVisible="{Binding IsResponseFormatTextVisible}" />
                                <TextBox Grid.Row="2"
                                         IsVisible="{Binding IsResponseFormatTextVisible}"
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="{DynamicResource CodeFontFamily}"
                                         FontSize="12"
                                         Text="{Binding ResponseFormatText, Mode=TwoWay}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                <!-- Empty-state hint for Off / Json, where no editor is needed. -->
                                <TextBlock Grid.Row="2"
                                           IsVisible="{Binding !IsResponseFormatTextVisible}"
                                           Classes="muted sm"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Top"
                                           Text="Off disables grammar-based sampling — the model writes freely. Json forces the output to be any valid JSON value without constraining shape." />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Classes="card" Margin="8,0,0,0">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Text="Compiled GBNF"
                                           Classes="section" Margin="0,0,0,8" />
                                <ScrollViewer Grid.Row="1" Padding="0,0,8,0">
                                    <SelectableTextBlock
                                        Text="{Binding CompiledGbnfPreview}"
                                        FontFamily="{DynamicResource CodeFontFamily}"
                                        FontSize="12"
                                        TextWrapping="NoWrap" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Classes="statusbar" Padding="20,12">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Status}" Classes="xs muted"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Content="Save" Margin="8,0,6,0"
                        Command="{Binding SaveCommand}" />
                <Button Grid.Column="2" Content="Close" Classes="outline"
                        Click="OnCloseClicked" />
            </Grid>
        </Border>
    </Grid>
</Window>
