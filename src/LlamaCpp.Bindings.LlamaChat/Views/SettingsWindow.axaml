<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LlamaCpp.Bindings.LlamaChat.ViewModels"
        xmlns:v="using:LlamaCpp.Bindings.LlamaChat.Views"
        mc:Ignorable="d"
        d:DesignWidth="900" d:DesignHeight="700"
        x:Class="LlamaCpp.Bindings.LlamaChat.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="Settings"
        Width="900" Height="700" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Classes="panel" Padding="20,14">
            <TextBlock Text="Settings" Classes="h2" />
        </Border>

        <!-- Body: profile list | editor -->
        <Grid Grid.Row="1" ColumnDefinitions="260,*" Margin="16">

            <Border Grid.Column="0"
                    Background="{DynamicResource Sidebar}"
                    BorderBrush="{DynamicResource SidebarBorder}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource RadiusLg}">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="Profiles" Classes="section" Margin="14,12,14,6" />
                    <ListBox Grid.Row="1" Margin="6"
                             ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:ProfileEditorViewModel">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10" Spacing="6">
                        <Button Content="Add" Classes="sm outline"
                                Command="{Binding AddProfileCommand}" />
                        <Button Content="Duplicate" Classes="sm outline"
                                Command="{Binding DuplicateProfileCommand}" />
                        <Button Content="Delete" Classes="sm destructive"
                                Command="{Binding DeleteProfileCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="16,0,0,0"
                    Classes="card">
                <ScrollViewer>
                    <ContentControl Content="{Binding SelectedProfile}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate DataType="vm:ProfileEditorViewModel">
                                <v:ProfileEditorView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Classes="statusbar" Padding="20,12">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Status}" Classes="xs muted"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Content="Save" Margin="8,0,6,0"
                        Command="{Binding SaveCommand}" />
                <Button Grid.Column="2" Content="Close" Classes="outline"
                        Click="OnCloseClicked" />
            </Grid>
        </Border>

    </Grid>
</Window>
