<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LlamaCpp.Bindings.LlamaChat.ViewModels"
        xmlns:views="using:LlamaCpp.Bindings.LlamaChat.Views"
        xmlns:a="using:Avalonia.Automation"
        mc:Ignorable="d"
        d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="LlamaCpp.Bindings.LlamaChat.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LlamaChat"
        Icon="/Assets/icon-256.png"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="500"
        DragDrop.AllowDrop="True"
        Classes.a11y="{Binding AppSettings.HighAccessibilityMode}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewConversationCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding NewConversationCommand}" />
        <KeyBinding Gesture="Ctrl+B" Command="{Binding ToggleSidebarCommand}" />
        <KeyBinding Gesture="Ctrl+L" Command="{Binding LoadCommand}" />
        <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}" />
    </Window.KeyBindings>

    <Panel>
    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New chat"   Command="{Binding NewConversationCommand}" InputGesture="Ctrl+N" />
                <MenuItem Header="_Load model" Command="{Binding LoadCommand}"            InputGesture="Ctrl+L" />
                <MenuItem Header="_Unload"     Command="{Binding UnloadCommand}" />
                <MenuItem Header="Model _info..." Command="{Binding ShowModelInfoCommand}" />
                <Separator />
                <MenuItem Header="_Export conversations..." Command="{Binding ExportConversationsCommand}" />
                <MenuItem Header="_Import conversations..." Command="{Binding ImportConversationsCommand}" />
                <Separator />
                <MenuItem Header="E_xit"       Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Chat">
                <MenuItem Header="_Clear conversation" Command="{Binding ClearConversationCommand}" />
                <MenuItem Header="Cancel generation"   Command="{Binding CancelCommand}" />
                <MenuItem Header="_Delete conversation" Command="{Binding DeleteConversationCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _sidebar" Command="{Binding ToggleSidebarCommand}" InputGesture="Ctrl+B" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Preferences..." Command="{Binding OpenSettingsCommand}" InputGesture="Ctrl+," />
                <Separator />
                <MenuItem Header="_MCP execution log..." Command="{Binding ShowMcpLogCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Keyboard _shortcuts..." Command="{Binding ShowShortcutsCommand}" />
                <Separator />
                <MenuItem Header="_About..." Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar: active profile + model actions + active MCP servers -->
        <Border DockPanel.Dock="Top" Classes="panel" Padding="12,8">
            <Grid ColumnDefinitions="Auto,Auto,240,Auto,Auto,Auto,*,Auto">
                <!-- Sidebar toggle — first thing on the toolbar so it anchors
                     the top-left corner and mirrors the conversation-list
                     control it affects. Ctrl+B is bound on the Window. -->
                <Button Grid.Column="0" Classes="ghost icon"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip.Tip="Toggle sidebar (Ctrl+B)"
                        a:AutomationProperties.Name="Toggle sidebar"
                        Margin="0,0,8,0">
                    <Path Classes="icon" Data="{StaticResource IconPanelLeft}" />
                </Button>
                <TextBlock Grid.Column="1" Text="Profile" Classes="muted sm"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          IsEnabled="{Binding !IsModelLoaded}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="vm:ProfileEditorViewModel">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="3" Margin="8,0,0,0"
                        Command="{Binding LoadCommand}"
                        ToolTip.Tip="Load selected profile (Ctrl+L)"
                        a:AutomationProperties.Name="Load selected profile">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource IconPlay}" />
                        <TextBlock Text="Load" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="4" Classes="outline" Margin="6,0,0,0"
                        Command="{Binding UnloadCommand}"
                        ToolTip.Tip="Unload model"
                        a:AutomationProperties.Name="Unload model">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource IconUnplug}" />
                        <TextBlock Text="Unload" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="5" Classes="outline" Margin="6,0,0,0"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip.Tip="Preferences (Ctrl+,)"
                        a:AutomationProperties.Name="Open preferences">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon sm" Data="{StaticResource IconSettings}" />
                        <TextBlock Text="Settings" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <!-- Loaded-model info strip: profile name + modality badges + the
                     rest of the summary. Badges self-hide when the loaded model
                     lacks that modality; entire strip is empty when nothing is loaded. -->
                <StackPanel Grid.Column="6" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0" Spacing="6">
                    <TextBlock Text="{Binding ProfileDisplayName}"
                               Classes="muted xs" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <Border IsVisible="{Binding CanAttachImages}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            Background="{DynamicResource Muted}"
                            CornerRadius="4" Padding="4,2"
                            ToolTip.Tip="Vision-capable — accepts image attachments"
                            a:AutomationProperties.Name="Vision capable">
                        <Path Classes="icon xs" Data="{StaticResource IconEye}" />
                    </Border>
                    <Border IsVisible="{Binding CanAttachAudio}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            Background="{DynamicResource Muted}"
                            CornerRadius="4" Padding="4,2"
                            ToolTip.Tip="Audio-capable — accepts audio attachments and mic"
                            a:AutomationProperties.Name="Audio capable">
                        <Path Classes="icon xs" Data="{StaticResource IconVolume}" />
                    </Border>
                    <TextBlock Text="{Binding ModelSummary}" Classes="muted xs"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Active MCP servers: compact avatar strip. Each server
                     shows its first-letter initial in a circle. Click
                     opens the log dialog; tooltip shows name + tools count. -->
                <ItemsControl Grid.Column="7" ItemsSource="{Binding ActiveMcpServers}"
                              VerticalAlignment="Center" Margin="12,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="26" Height="26" CornerRadius="13"
                                    Background="{DynamicResource Accent}"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                    ToolTip.Tip="{Binding Config.Name, StringFormat='MCP: {0}'}"
                                    a:AutomationProperties.Name="{Binding Config.Name, StringFormat='MCP server {0}'}">
                                <TextBlock Text="{Binding Config.Name, Converter={StaticResource FirstLetter}}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentForeground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Classes="statusbar">
            <TextBlock Text="{Binding StatusText}" Classes="xs muted" />
        </Border>

        <!-- Body = sidebar + main -->
        <Grid ColumnDefinitions="Auto,*">

            <!-- ================= Sidebar ================= -->
            <Border Grid.Column="0"
                    IsVisible="{Binding IsSidebarVisible}"
                    Width="280"
                    Background="{DynamicResource Sidebar}"
                    BorderBrush="{DynamicResource SidebarBorder}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- New chat button -->
                    <Button Grid.Row="0"
                            Classes="outline"
                            Margin="10,10,10,6"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Command="{Binding NewConversationCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Classes="icon sm" Data="{StaticResource IconPlus}" />
                            <TextBlock Text="New chat" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Search -->
                    <TextBox Grid.Row="1" Name="SearchBox"
                             Margin="10,0,10,6"
                             Text="{Binding SearchText}"
                             PlaceholderText="Search conversations..." />

                    <!-- Conversation list -->
                    <ListBox Grid.Row="2"
                             Margin="4,0,4,6"
                             ItemsSource="{Binding FilteredConversations}"
                             SelectedItem="{Binding SelectedConversation}">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="10,8" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:ConversationViewModel">
                                <!-- Background=Transparent so the whole card is hit-testable
                                     for right-click, not just the text glyphs. -->
                                <Grid Background="Transparent">
                                    <!-- Default display -->
                                    <StackPanel Spacing="2" IsVisible="{Binding !IsEditing}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DisplayTitle}"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Path Grid.Column="1" Classes="icon xs"
                                                  Data="{StaticResource IconPin}"
                                                  Opacity="0.7" Margin="6,0,0,0"
                                                  IsVisible="{Binding Pinned}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Preview}"
                                                   Classes="muted xs"
                                                   IsVisible="{Binding Preview, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <!-- Inline rename -->
                                    <TextBox Text="{Binding Title, Mode=TwoWay}"
                                             IsVisible="{Binding IsEditing}"
                                             KeyDown="OnRenameKeyDown"
                                             LostFocus="OnRenameLostFocus"
                                             AttachedToVisualTree="OnRenameAttached" />
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Rename"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BeginRenameCommand}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="Pin / unpin"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).TogglePinnedCommand}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="Delete"
                                                      Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteConversationCommand}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ================= Main (messages + compose) ================= -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto,Auto" Margin="16,12,16,12">

                <!-- Empty-conversation placeholder: centred hint when the
                     selected conversation has no messages. Sits behind the
                     ScrollViewer so it appears through the empty list. -->
                <Panel Grid.Row="0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="8"
                                IsVisible="{Binding SelectedConversation.Messages.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                        <TextBlock Text="Start the conversation" Classes="h2"
                                   HorizontalAlignment="Center" />
                        <TextBlock Classes="muted sm" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"
                                   Text="Type a message below and press Enter to send. Shift+Enter for a new line." />
                    </StackPanel>

                    <ScrollViewer Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SelectedConversation.Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:MessageViewModel">
                                <Border Classes="bubble"
                                        Classes.user="{Binding IsUser}"
                                        Classes.assistant="{Binding IsAssistant}"
                                        Classes.tool="{Binding IsTool}"
                                        a:AutomationProperties.Name="{Binding Role, StringFormat='{}{0} message'}"
                                        a:AutomationProperties.LiveSetting="Polite">
                                    <StackPanel Spacing="6">
                                        <!-- Role header row — user/assistant only. The tool
                                             bubble's Expander.Header carries 🔧 + the tool
                                             name instead, so this line would duplicate it.
                                             When the message has siblings a compact
                                             ‹ N/M › nav pill appears next to the role label. -->
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    IsVisible="{Binding !IsTool}">
                                            <TextBlock Text="{Binding Role}" Classes="xs"
                                                       FontWeight="SemiBold" Opacity="0.7"
                                                       VerticalAlignment="Center" />
                                            <Border Classes="toolchip"
                                                    IsVisible="{Binding HasSiblings}"
                                                    Padding="2,0"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="2">
                                                    <Button Classes="ghost icon sm"
                                                            ToolTip.Tip="Previous branch"
                                                            a:AutomationProperties.Name="Previous branch"
                                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SwitchPrevSiblingCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="‹" FontSize="14"
                                                                   VerticalAlignment="Center" />
                                                    </Button>
                                                    <TextBlock Classes="xs muted"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding SiblingIndex, StringFormat='{}{0}'}" />
                                                    <TextBlock Classes="xs muted" Text="/"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Classes="xs muted"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding SiblingCount}" />
                                                    <Button Classes="ghost icon sm"
                                                            ToolTip.Tip="Next branch"
                                                            a:AutomationProperties.Name="Next branch"
                                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SwitchNextSiblingCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="›" FontSize="14"
                                                                   VerticalAlignment="Center" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Read-only view -->
                                        <StackPanel Spacing="6" IsVisible="{Binding !IsEditing}">
                                            <!-- Attached images (if any). A simple horizontal strip
                                                 above the text content; clicking not yet wired to a
                                                 full-size preview. Keeps the bubble visual even after
                                                 a conversation is reloaded from the JSON store. -->
                                            <ItemsControl ItemsSource="{Binding Attachments}"
                                                          IsVisible="{Binding HasAttachments}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,6" CornerRadius="6"
                                                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                                Background="{DynamicResource Muted}"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <!-- Image: actual thumbnail. -->
                                                                <Image IsVisible="{Binding IsImage}"
                                                                       Source="{Binding Converter={StaticResource AttachmentThumbnail}}"
                                                                       Width="180" MaxHeight="200"
                                                                       Stretch="Uniform" />
                                                                <!-- Audio: filename chip. No decoded waveform preview
                                                                     in v1 — the raw bytes could be MP3/FLAC/etc. and
                                                                     we'd need a proper decoder (miniaudio is
                                                                     native-side only) to draw them. -->
                                                                <StackPanel IsVisible="{Binding IsAudio}"
                                                                            Orientation="Horizontal" Spacing="6"
                                                                            Margin="10,8">
                                                                    <Path Classes="icon"
                                                                          Data="{StaticResource IconVolume}"
                                                                          VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding FileName, FallbackValue=audio}"
                                                                               Classes="sm" VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               MaxWidth="200" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Expander Header="Reasoning"
                                                      IsVisible="{Binding HasReasoning}"
                                                      IsExpanded="{Binding IsReasoningExpanded}">
                                                <SelectableTextBlock Text="{Binding Reasoning}"
                                                                     Classes="sm muted"
                                                                     TextWrapping="Wrap" />
                                            </Expander>
                                            <!-- ASR language chip: compact pill
                                                 showing the detected transcription
                                                 language (Qwen3-ASR only). Sits
                                                 above the main content. -->
                                            <Border IsVisible="{Binding HasAsrLanguage}"
                                                    HorizontalAlignment="Left"
                                                    Background="{DynamicResource Muted}"
                                                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                    CornerRadius="10" Padding="8,2">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <Path Classes="icon xs" Data="{StaticResource IconGlobe}"
                                                          VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding AsrLanguage}"
                                                               Classes="xs muted" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <!-- Tool-call chips: one compact pill per tool
                                                 the assistant asked for. Shown above the
                                                 visible reply so the reader sees "what was
                                                 called" at a glance without having to read
                                                 XML. The actual markup still lives in
                                                 Content for the re-prompting round-trip. -->
                                            <ItemsControl ItemsSource="{Binding ToolCallChips}"
                                                          IsVisible="{Binding HasToolCalls}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Hover tooltip exposes the raw
                                                             <tool_call> markup so the user
                                                             can inspect the exact payload
                                                             the model emitted without it
                                                             eating transcript space. -->
                                                        <Border Classes="toolchip" Margin="0,0,6,4"
                                                                ToolTip.Tip="{Binding RawMatch}">
                                                            <StackPanel Orientation="Horizontal" Spacing="4"
                                                                        VerticalAlignment="Center">
                                                                <Path Classes="icon xs" Data="{StaticResource IconWrench}"
                                                                      VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding Name}"
                                                                           Classes="xs" FontWeight="SemiBold"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text="("
                                                                           Classes="xs muted"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text="{Binding ArgsDisplay}"
                                                                           Classes="xs muted"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="320"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text=")"
                                                                           Classes="xs muted"
                                                                           VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- MarkdownView only renders when there's text
                                                 to show after stripping tool-call markup.
                                                 Pure tool-call replies (common with Qwen3)
                                                 leave DisplayContent empty; the chip row
                                                 above carries all the meaningful info. -->
                                            <views:MarkdownView Markdown="{Binding DisplayContent}"
                                                                IsStreaming="{Binding IsStreaming}"
                                                                IsVisible="{Binding HasDisplayContent}" />

                                            <!-- Tool result: always in an Expander so the
                                                 collapse chevron is visible regardless of
                                                 length. Short results open by default, long
                                                 ones stay collapsed. Header combines the
                                                 tool name with (when collapsed) a first-line
                                                 peek. The MCP execution-log dialog keeps
                                                 the raw wire envelope if it's needed. -->
                                            <Expander IsVisible="{Binding IsTool}"
                                                      IsExpanded="{Binding IsToolExpanded, Mode=TwoWay}">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Path Classes="icon sm" Data="{StaticResource IconWrench}"
                                                              Opacity="0.7"
                                                              VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding ToolName, FallbackValue=tool}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="·" Classes="xs muted"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding !IsToolExpanded}" />
                                                        <TextBlock Text="{Binding ToolPeek}"
                                                                   Classes="xs muted"
                                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="420"
                                                                   IsVisible="{Binding !IsToolExpanded}" />
                                                    </StackPanel>
                                                </Expander.Header>
                                                <Border Classes="toolresult">
                                                    <SelectableTextBlock Text="{Binding Content}" />
                                                </Border>
                                            </Expander>
                                            <TextBlock Text="{Binding StatsSummary}" Classes="xs muted"
                                                       IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AppSettings.ShowMessageStats}" />

                                            <!-- Action bar. Icon-only ghost buttons with tooltips —
                                                 the icons read at a glance for the common actions and
                                                 the tooltip covers the less obvious ones. Hidden by
                                                 default; fades in on bubble hover (styles in
                                                 Theme/Controls.axaml). -->
                                            <StackPanel Classes="actions"
                                                        Orientation="Horizontal" Spacing="2" Margin="-2,4,-2,-4"
                                                        IsVisible="{Binding !IsStreaming}">
                                                <Button Classes="ghost icon sm"
                                                        ToolTip.Tip="Copy"
                                                        a:AutomationProperties.Name="Copy message"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CopyMessageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Classes="icon xs" Data="{StaticResource IconCopy}" />
                                                </Button>
                                                <Button Classes="ghost icon sm"
                                                        ToolTip.Tip="Edit"
                                                        a:AutomationProperties.Name="Edit message"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BeginEditMessageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Classes="icon xs" Data="{StaticResource IconPencil}" />
                                                </Button>
                                                <Button Classes="ghost icon sm"
                                                        IsVisible="{Binding IsAssistant}"
                                                        ToolTip.Tip="Regenerate"
                                                        a:AutomationProperties.Name="Regenerate reply"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RegenerateMessageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Classes="icon xs" Data="{StaticResource IconRotateCw}" />
                                                </Button>
                                                <Button Classes="ghost icon sm"
                                                        IsVisible="{Binding IsAssistant}"
                                                        ToolTip.Tip="Continue — extend this reply without re-prompting (last message only)"
                                                        a:AutomationProperties.Name="Continue reply"
                                                        a:AutomationProperties.HelpText="Extend this reply without re-prompting (last message only)"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ContinueMessageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Classes="icon xs" Data="{StaticResource IconPlay}" />
                                                </Button>
                                                <Button Classes="ghost icon sm"
                                                        ToolTip.Tip="Delete"
                                                        a:AutomationProperties.Name="Delete message"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteMessageCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Path Classes="icon xs" Data="{StaticResource IconTrash}" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Inline edit -->
                                        <StackPanel Spacing="6" IsVisible="{Binding IsEditing}">
                                            <TextBox Text="{Binding EditDraft, Mode=TwoWay}"
                                                     AcceptsReturn="True" TextWrapping="Wrap"
                                                     MinHeight="60" MaxHeight="280" />
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Right">
                                                <Button Content="Save"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CommitEditMessageCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Content="Cancel" Classes="outline"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CancelEditMessageCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </Panel>

                <!-- Remedy card: surfaces when the active path's leaf is a
                     user turn (e.g. after deleting the last assistant reply
                     with a tree-aware delete). One click regenerates a
                     fresh reply; the card hides itself once something answers
                     the dangling turn. -->
                <Border Grid.Row="1"
                        Classes="panel"
                        Padding="12,8"
                        Margin="0,8,0,0"
                        CornerRadius="{DynamicResource RadiusMd}"
                        IsVisible="{Binding SelectedConversation.NeedsAssistantReply}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="sm muted"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="The last turn is a user message with no reply." />
                        <Button Grid.Column="1" Classes="sm"
                                Command="{Binding GenerateReplyCommand}"
                                IsEnabled="{Binding IsModelLoaded}"
                                ToolTip.Tip="Generate a reply to the dangling user turn"
                                a:AutomationProperties.Name="Generate reply">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Path Classes="icon xs" Data="{StaticResource IconPlay}" />
                                <TextBlock Text="Generate reply" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,*,Auto"
                      Margin="0,12,0,0">
                    <!-- Pending-attachment thumbnail strip. Sits above the
                         TextBox and only renders when there's something to
                         show — keeps the compose area compact otherwise.
                         The strip self-caps at a handful of tiles; an overflow
                         tile next to it opens the gallery modal when more
                         attachments are queued than fit comfortably inline. -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3"
                                Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding HasPendingAttachments}"
                                Margin="0,0,0,6">
                        <ItemsControl ItemsSource="{Binding VisiblePendingAttachments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                            CornerRadius="6" Background="{DynamicResource Muted}"
                                            Padding="2" Width="72" Height="72"
                                            ToolTip.Tip="{Binding FileName}">
                                        <Grid>
                                            <Image IsVisible="{Binding IsImage}"
                                                   Source="{Binding Converter={StaticResource AttachmentThumbnail}}"
                                                   Stretch="UniformToFill" />
                                            <Path IsVisible="{Binding IsAudio}"
                                                  Classes="icon lg" Data="{StaticResource IconVolume}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                            <Button Classes="ghost icon sm"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Width="18" Height="18"
                                                    Background="{DynamicResource Card}"
                                                    CornerRadius="9" Margin="0,-4,-4,0"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemovePendingAttachmentCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Remove"
                                                    a:AutomationProperties.Name="Remove attachment">
                                                <Path Classes="icon xs" Data="{StaticResource IconX}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Overflow tile: visible when there are more pending
                             attachments than fit inline. Click opens the gallery. -->
                        <Button Classes="ghost" Width="72" Height="72" Padding="0"
                                IsVisible="{Binding HasAttachmentOverflow}"
                                Command="{Binding ShowPendingAttachmentsCommand}"
                                ToolTip.Tip="View all pending attachments"
                                a:AutomationProperties.Name="View all pending attachments">
                            <Border BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                    CornerRadius="6" Background="{DynamicResource Muted}"
                                    Padding="2">
                                <TextBlock Text="{Binding OverflowAttachmentCount, StringFormat='+{0}'}"
                                           FontSize="18" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Foreground}" />
                            </Border>
                        </Button>
                    </StackPanel>

                    <!-- Attach / prompt / resource buttons stacked vertically so
                         we don't eat horizontal space in the compose row. -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Vertical"
                                Spacing="2" Margin="0,0,6,0" VerticalAlignment="Top">
                        <Button Classes="ghost icon"
                                ToolTip.Tip="Attach image or audio (paste or drop works too)"
                                a:AutomationProperties.Name="Attach file"
                                a:AutomationProperties.HelpText="Attach image or audio. Paste or drop also works."
                                Command="{Binding AttachMediaCommand}"
                                IsEnabled="{Binding CanAttachMedia}">
                            <Path Classes="icon" Data="{StaticResource IconPaperclip}" />
                        </Button>
                        <Button Classes="ghost icon"
                                ToolTip.Tip="Insert MCP prompt"
                                a:AutomationProperties.Name="Insert MCP prompt"
                                Command="{Binding InsertMcpPromptCommand}">
                            <Path Classes="icon" Data="{StaticResource IconZap}" />
                        </Button>
                        <Button Classes="ghost icon"
                                ToolTip.Tip="Browse MCP resources"
                                a:AutomationProperties.Name="Browse MCP resources"
                                Command="{Binding AttachMcpResourceCommand}">
                            <Path Classes="icon" Data="{StaticResource IconFolder}" />
                        </Button>
                        <!-- Mic: toggle-style record button. Icon swaps to a stop
                             square while recording; live mm:ss sits under the box. -->
                        <Button Classes="ghost icon"
                                ToolTip.Tip="Record from microphone"
                                a:AutomationProperties.Name="Record audio from microphone"
                                Command="{Binding ToggleRecordCommand}"
                                IsVisible="{Binding CanAttachAudio}">
                            <Grid>
                                <Path Classes="icon" Data="{StaticResource IconMic}"
                                      IsVisible="{Binding !IsRecording}" />
                                <Path Classes="icon" Data="{StaticResource IconSquare}"
                                      Stroke="{DynamicResource Destructive}"
                                      IsVisible="{Binding IsRecording}" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <TextBox Grid.Column="1" Grid.Row="1" Name="ComposeBox"
                             Text="{Binding UserInput, Mode=TwoWay}"
                             PlaceholderText="Type a message, Shift+Enter for newline..."
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="56" MaxHeight="200" />
                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal"
                                Spacing="10" Margin="4,2,0,0">
                        <TextBlock Classes="xs muted"
                                   IsVisible="{Binding IsModelLoaded}"
                                   Text="{Binding UserInputTokenCount, StringFormat='{}{0} tok'}" />
                        <!-- Recording indicator: a pulsing red dot + live mm:ss duration. -->
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding IsRecording}"
                                    a:AutomationProperties.LiveSetting="Polite">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource Destructive}"
                                     VerticalAlignment="Center" />
                            <TextBlock Classes="xs"
                                       Foreground="{DynamicResource Destructive}"
                                       VerticalAlignment="Center"
                                       Text="{Binding RecordingDuration, StringFormat='Recording {0}'}" />
                        </StackPanel>
                    </StackPanel>
                    <!-- Send and Stop share a column — only one is visible at a
                         time depending on IsGenerating. Matches webui's toggle. -->
                    <Button Grid.Column="2" Grid.Row="1" Margin="8,0,0,0"
                            Command="{Binding SendCommand}" IsDefault="True"
                            IsVisible="{Binding !IsGenerating}"
                            ToolTip.Tip="Send (Enter)"
                            a:AutomationProperties.Name="Send message">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Classes="icon sm" Data="{StaticResource IconSend}" />
                            <TextBlock Text="Send" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Grid.Row="1" Classes="destructive" Margin="8,0,0,0"
                            Command="{Binding CancelCommand}"
                            IsVisible="{Binding IsGenerating}"
                            ToolTip.Tip="Stop generation"
                            a:AutomationProperties.Name="Stop generation">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Path Classes="icon sm" Data="{StaticResource IconSquare}" />
                            <TextBlock Text="Stop" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>

    <!-- Model-loading splash. Covers the main UI (including menus) while
         ChatSession.Load runs, so the user knows work is happening and
         can't kick off a second load. Blurs the background visually via
         the semi-transparent overlay. -->
    <Border IsVisible="{Binding IsBusy}"
            Background="{DynamicResource Background}" Opacity="0.92">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="14" MinWidth="320">
            <TextBlock Text="Loading model" Classes="h2" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding SelectedProfile.Name}" Classes="muted sm"
                       HorizontalAlignment="Center" />
            <ProgressBar IsIndeterminate="True" Height="4" Width="280" />
            <TextBlock Text="{Binding StatusText}" Classes="xs muted"
                       HorizontalAlignment="Center" MaxWidth="420"
                       TextWrapping="Wrap" TextAlignment="Center" />
        </StackPanel>
    </Border>

    <!-- Toast overlay — visual layer sits above DockPanel so cards appear
         over the chat. IsHitTestVisible=false on the host ensures clicks
         pass through to the main UI. -->
    <views:ToastHost />
    </Panel>
</Window>
