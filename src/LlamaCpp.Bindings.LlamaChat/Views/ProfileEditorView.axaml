<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LlamaCpp.Bindings.LlamaChat.ViewModels"
             xmlns:v="using:LlamaCpp.Bindings.LlamaChat.Views"
             xmlns:bindings="using:LlamaCpp.Bindings"
             mc:Ignorable="d"
             x:Class="LlamaCpp.Bindings.LlamaChat.Views.ProfileEditorView"
             x:DataType="vm:ProfileEditorViewModel">

    <UserControl.Styles>
        <!-- TextBlock.section is defined globally in Theme/Controls.axaml -->
        <Style Selector="Grid.row">
            <Setter Property="Margin" Value="0,3" />
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="2">

        <TextBlock Classes="section" Text="Identity" />
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="Profile name" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding Name}" />
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="Backend" VerticalAlignment="Center"
                       ToolTip.Tip="Local: load a GGUF in-process. Remote: connect to an OpenAI-compatible HTTP server (e.g. LlamaCpp.Bindings.Server)." />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <RadioButton Content="Local" GroupName="ProfileKind"
                             IsChecked="{Binding IsLocal, Mode=OneWay}"
                             Click="OnKindLocalClicked" />
                <RadioButton Content="Remote" GroupName="ProfileKind"
                             IsChecked="{Binding IsRemote, Mode=OneWay}"
                             Click="OnKindRemoteClicked" />
            </StackPanel>
        </Grid>

        <TextBlock Classes="section" Text="System prompt" />
        <TextBox Text="{Binding SystemPrompt}"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="80" MaxHeight="240"
                 PlaceholderText="Optional. Prepended as a system-role turn at the start of every reply." />

        <!-- ===== Remote backend ===== -->
        <StackPanel Spacing="2" IsVisible="{Binding IsRemote}">
            <TextBlock Classes="section" Text="Server" />
            <Grid Classes="row" ColumnDefinitions="130,*">
                <TextBlock Grid.Column="0" Text="Base URL" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Text="{Binding BaseUrl}"
                         PlaceholderText="http://localhost:8080" />
            </Grid>
            <Grid Classes="row" ColumnDefinitions="130,*">
                <TextBlock Grid.Column="0" Text="API key" VerticalAlignment="Center"
                           ToolTip.Tip="Optional. Sent as 'Authorization: Bearer ...'. Stored plaintext in profiles.json — same convention as the rest of LlamaChat's config." />
                <TextBox Grid.Column="1" Text="{Binding ApiKey}"
                         PasswordChar="*"
                         PlaceholderText="Optional. Sent as Authorization: Bearer ..." />
            </Grid>
            <Grid Classes="row" ColumnDefinitions="130,*,Auto">
                <TextBlock Grid.Column="0" Text="Model id" VerticalAlignment="Center"
                           ToolTip.Tip="The 'model' field sent with each request. Click Discover to populate from /v1/models." />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableModels}"
                          SelectedItem="{Binding ModelId}"
                          IsTextSearchEnabled="True"
                          HorizontalAlignment="Stretch" />
                <Button Grid.Column="2" Content="Discover" Margin="4,0,0,0"
                        Command="{Binding DiscoverRemoteModelsCommand}" />
            </Grid>
            <TextBlock Classes="xs muted" TextWrapping="Wrap"
                       Text="{Binding DiscoverStatus}"
                       IsVisible="{Binding DiscoverStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <!-- ===== Local backend ===== -->
        <StackPanel Spacing="2" IsVisible="{Binding IsLocal}">
        <TextBlock Classes="section" Text="Model" />
        <Grid Classes="row" ColumnDefinitions="130,*,Auto">
            <TextBlock Grid.Column="0" Text="Model path" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding ModelPath}" PlaceholderText="Path to .gguf" />
            <Button Grid.Column="2" Content="Browse..." Margin="4,0,0,0"
                    Command="{Binding $parent[v:SettingsWindow].((vm:SettingsWindowViewModel)DataContext).BrowseModelPathCommand}" />
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*,Auto,Auto">
            <TextBlock Grid.Column="0" Text="mmproj (optional)" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding MmprojPath}"
                     PlaceholderText="Vision/audio projector .gguf — required for image attachments" />
            <Button Grid.Column="2" Content="Browse..." Margin="4,0,0,0"
                    Command="{Binding $parent[v:SettingsWindow].((vm:SettingsWindowViewModel)DataContext).BrowseMmprojPathCommand}" />
            <Button Grid.Column="3" Content="Clear" Classes="ghost" Margin="4,0,0,0"
                    Command="{Binding $parent[v:SettingsWindow].((vm:SettingsWindowViewModel)DataContext).ClearMmprojPathCommand}" />
        </Grid>
        <CheckBox Content="Force vision encoder on CPU (fallback for buggy CUDA CLIP graphs, e.g. Qwen3-VL)"
                  IsChecked="{Binding MmprojOnCpu}"
                  IsEnabled="{Binding MmprojPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="Min image tokens" VerticalAlignment="Center"
                       ToolTip.Tip="0 = auto. Set to 1024+ for Qwen-VL grounding tasks." />
            <NumericUpDown Grid.Column="1" Value="{Binding MmprojImageMinTokens}"
                           Minimum="0" Maximum="4096" Increment="128" FormatString="F0"
                           IsEnabled="{Binding MmprojPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </Grid>

        <TextBlock Classes="section" Text="Load" />
        <Grid Classes="row" ColumnDefinitions="130,*,Auto">
            <TextBlock Grid.Column="0" Text="Auto-configure" VerticalAlignment="Center"
                       ToolTip.Tip="Probe the GGUF + local hardware and suggest context size, GPU layers, KV cache type, and publisher-recommended sampler values." />
            <TextBlock Grid.Column="1" Classes="muted xs" TextWrapping="Wrap" VerticalAlignment="Center"
                       Text="Requires a valid Model path. Overwrites load + sampler fields; you can tweak before saving." />
            <Button Grid.Column="2" Margin="4,0,0,0"
                    Command="{Binding $parent[v:SettingsWindow].((vm:SettingsWindowViewModel)DataContext).AutoConfigureCommand}"
                    ToolTip.Tip="Probe this model and hardware, then populate the settings below.">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="icon sm" Data="{StaticResource IconSparkles}" />
                    <TextBlock Text="Automagic" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="Context size" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Value="{Binding ContextSize}" Minimum="128" Increment="512" FormatString="F0" />
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="GPU layers" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Value="{Binding GpuLayerCount}" Minimum="-1" Increment="1" FormatString="F0" />
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="Logical batch" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Value="{Binding LogicalBatchSize}" Minimum="32" Increment="64" FormatString="F0" />
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="Physical batch" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Value="{Binding PhysicalBatchSize}" Minimum="32" Increment="64" FormatString="F0" />
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*">
            <TextBlock Grid.Column="0" Text="Flash attention" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" SelectedItem="{Binding FlashAttention}">
                <ComboBox.Items>
                    <bindings:LlamaFlashAttention>Auto</bindings:LlamaFlashAttention>
                    <bindings:LlamaFlashAttention>Disabled</bindings:LlamaFlashAttention>
                    <bindings:LlamaFlashAttention>Enabled</bindings:LlamaFlashAttention>
                </ComboBox.Items>
            </ComboBox>
        </Grid>
        <Grid Classes="row" ColumnDefinitions="130,*"
              ToolTip.Tip="Element type for the KV cache. Quantized (Q*/IQ*) halves or quarters memory use at a small accuracy cost on long contexts, and requires Flash Attention.">
            <TextBlock Grid.Column="0" Text="KV cache type" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Spacing="4">
                <ComboBox SelectedItem="{Binding KvCacheType}">
                    <ComboBox.Items>
                        <bindings:LlamaKvCacheType>F16</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>BF16</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>F32</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>Q8_0</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>Q5_1</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>Q5_0</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>Q4_1</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>Q4_0</bindings:LlamaKvCacheType>
                        <bindings:LlamaKvCacheType>IQ4_NL</bindings:LlamaKvCacheType>
                    </ComboBox.Items>
                </ComboBox>
                <TextBlock Classes="xs"
                           Foreground="{DynamicResource Destructive}"
                           TextWrapping="Wrap"
                           IsVisible="{Binding FlashAttentionHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Text="{Binding FlashAttentionHint}" />
            </StackPanel>
        </Grid>
        <CheckBox Content="mmap" IsChecked="{Binding UseMmap}" />
        <CheckBox Content="mlock" IsChecked="{Binding UseMlock}" />
        <CheckBox Content="offload KQV" IsChecked="{Binding OffloadKQV}" />
        </StackPanel>
        <!-- ===== /Local backend ===== -->

        <TextBlock Classes="section" Text="Sampling" />
        <v:SamplerPanelView DataContext="{Binding SamplerPanel}" />

    </StackPanel>
</UserControl>
