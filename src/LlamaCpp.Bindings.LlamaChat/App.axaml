<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:LlamaCpp.Bindings.LlamaChat.Services"
             x:Class="LlamaCpp.Bindings.LlamaChat.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://LlamaCpp.Bindings.LlamaChat/Theme/Tokens.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <svc:AttachmentThumbnailConverter x:Key="AttachmentThumbnail" />
            <svc:JsonPrettyPrinter x:Key="JsonPrettyPrinter" />
            <svc:FirstLetterConverter x:Key="FirstLetter" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://LlamaCpp.Bindings.LlamaChat/Theme/Controls.axaml" />
    </Application.Styles>
</Application>
